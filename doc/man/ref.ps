()LN
EL
SL
(NAME)LN
EL
SL
(     Register - register as MOLMOL user)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     Register string string string string [ string ])LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Send an E-mail to register as MOLMOL user. The first)LN
EL
SL
(     argument gives your name, the second argument the name)LN
EL
SL
(     of the organisation \(university/company\) where you)LN
EL
SL
(     work, the third argument the S-mail address, the)LN
EL
SL
(     fourth argument the E-mail address. The fifth argument)LN
EL
SL
(     is the program name and release, just leave the value)LN
EL
SL
(     that is automatically filled in.)LN
EL
SL
()LN
EL
SL
(     Getting registered is strongly recommended, so that we)LN
EL
SL
(     can inform you of new releases and send you other)LN
EL
SL
(     useful information.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Register "Joe User" "Useless Univ.")LN
EL
SL
(         "Street 42, Nowhere, USA" "joe@useless.edu")LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960111)LN
EL

