(NAME)LN
EL
SL
(     Quit - quit the program)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     Quit \( yes | no \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Quit the program. If the argument is 'yes', it will)LN
EL
SL
(     save the program state \("dump"\) to the file)LN
EL
SL
(     molmol/dump in the users home directory. This file)LN
EL
SL
(     is read whenever the program is started again.)LN
EL
SL
()LN
EL
SL
(     The program state can also be saved and recovered)LN
EL
SL
(     to an arbitrary file by using the commands WriteDump)LN
EL
SL
(     and ReadDump.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Quit yes)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadDump, WriteDump)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     951013)LN
EL

