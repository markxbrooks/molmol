(NAME)LN
EL
SL
(     PlotVrml2 - make a VRML 2.0 \(VRML97\) plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotVrml2 fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Make a plot of the current screen contents in VRML)LN
EL
SL
(     \(Virtual Reality Modeling Language\) format. VRML is)LN
EL
SL
(     a standard format for transferring and displaying)LN
EL
SL
(     three-dimensional geometry on the World Wide Web.)LN
EL
SL
(     The created files follow the VRML97 standard, and)LN
EL
SL
(     should also be compatible with the very similar)LN
EL
SL
(     VRML 2.0 specifications.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotVrml2 /home/joe/MyPlot.wrl)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotFm*, PlotPs, PlotPov, PlotRib, PlotVrml1)LN
EL
SL
()LN
