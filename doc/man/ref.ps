SL
(         Hidden Surface Elimination: Eliminate display)LN
EL
SL
(             elements that are hidden by other elements)LN
EL
SL
(             closer to the viewpoint. If the hardware)LN
EL
SL
(             supports this feature, it is enabled by)LN
EL
SL
(             default. If it has to be emulated by the)LN
EL
SL
(             program, the display can get very slow.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Rendering 0 0 0 1 1 0 1 0)LN
EL
SL
