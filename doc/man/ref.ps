()LN
EL
SL
(NAME)LN
EL
SL
(     FigLimit - show map of distance constraints)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     FigLimit name name expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Create a figure showing a map with the number of)LN
EL
SL
(     distance constraints between residue pairs. The)LN
EL
SL
(     first argument gives a property name, the residues)LN
EL
SL
(     with this property set will be shown on the horizontal)LN
EL
SL
(     axis. The residues with the property given as second)LN
EL
SL
(     argument will be shown on the vertical axis.)LN
EL
SL
()LN
EL
SL
(     All selected distances are considered. If the two)LN
EL
SL
(     properties given as first and second argument are the)LN
EL
SL
(     same, upper limits are shown on the top-left side of)LN
EL
SL
(     the diagonal, lower limits on the bottom-right side.)LN
EL
SL
(     If the properties are different, the number of upper)LN
EL
SL
(     and lower limit constraints is shown together.)LN
EL
SL
()LN
EL
SL
(     The third argument gives the number of constraints)LN
EL
SL
(     required for a fully black square, the fourth argument)LN
EL
SL
(     the minimum number of constraints required for a)LN
EL
SL
(     square to be shown at all. The grey value of these)LN
EL
SL
(     squares is given as fifth argument \(0.0 is black,)LN
EL
SL
(     1.0 is white\).)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     FigLimit 'selected' 'selected' 5 1 0.7)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadUpl, ReadLol, DefPropRes, Group, FigOff,)LN
EL
SL
(     FigContact)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961127)LN
EL

