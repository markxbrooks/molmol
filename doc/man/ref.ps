(NAME)LN
EL
SL
(     PlotRib - make a RenderMan plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotRib fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Make a plot of the current screen contents in)LN
EL
SL
(     RenderMan Interface Bytestream \(RIB\) format. This)LN
EL
SL
(     can be used as input for an external rendering)LN
EL
SL
(     package to produce high quality pictures.)LN
EL
SL
()LN
EL
SL
(     Information about suitable renderers can be found)LN
EL
SL
(     at http://www.bmrt.org and http://www.pixar.com.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotRib /home/joe/MyPlot.rib)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPov, PlotVrml2)LN
EL
SL
