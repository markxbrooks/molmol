()LN
EL
SL
(NAME)LN
EL
SL
(     AddAtom - add new atom)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddAtom name name1 name2 name3 expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add an atom with the name given as first argument to)LN
EL
SL
(     all selected residues.)LN
EL
SL
()LN
EL
SL
(     name1 is the name of the atom where the new atom is)LN
EL
SL
(     attached. name2 is the name of the atom that is used)LN
EL
SL
(     to define the axis of the dihedral angle together)LN
EL
SL
(     with the atom name1. name3 is the name of the atom)LN
EL
SL
(     relative to which the dihedral angle is given.)LN
EL
SL
()LN
EL
SL
(     The first numeric argument gives the dihedral angle,)LN
EL
SL
(     the next one the angle between the axis of the)LN
EL
SL
(     dihedral angle and the bond between atom name1 and)LN
EL
SL
(     the new atom. The last argument gives the bond)LN
EL
SL
(     distance.)LN
EL
SL
()LN
EL
SL
(     If name1, name2 and name3 do not exist in a selected)LN
EL
SL
(     residue, or if name already exists, then no new atom)LN
EL
SL
(     is added for this residue, without an error message.)LN
EL
SL
()LN
EL
SL
(     A bond between the new atom and atom name1 is)LN
EL
SL
(     automatically added.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddAtom "HB2" "CB" "CA" "HB1" 120 120 1.5)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectRes, AddPseudo, RemoveAtom, WriteLib)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961206)LN
EL

grestore

