()LN
EL
SL
(NAME)LN
EL
SL
(     StyleTrajec - set display style of trajectories)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     StyleTrajec \( invisible | line | neon | ellipsoid \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the display style of all selected trajectories.)LN
EL
SL
(     The style 'neon' draws the trajectory using cylinders)LN
EL
SL
(     with round ends. The style 'ellipsoid' draws an)LN
EL
SL
(     ellipsoid for the principal axes of the atoms that)LN
EL
SL
(     define the trajectory.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     StyleTrajec neon)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectPrim, AddTrajec, ColorPrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980324)LN
EL

