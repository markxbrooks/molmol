SL
()LN
EL
SL
(NAME)LN
EL
SL
(     CalcAngle - calculate angular order parameters)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     CalcAngle)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Generate a report with angular order parameters for)LN
EL
SL
(     all selected angles in all selected molecules. The)LN
EL
SL
(     same number of angles must be selected in all selected)LN
EL
SL
(     molecules.)LN
EL
SL
()LN
EL
SL
(     The first column of the report will show an average)LN
EL
SL
(     angle. This is not an arithmetic average, but the)LN
EL
SL
(     angle of the resulting vector sum used for the)LN
EL
SL
(     calculation of the angular order parameters.)LN
EL
SL
()LN
EL
SL
(     The second number is the standard deviation from)LN
EL
SL
(     this average.)LN
EL
SL
()LN
EL
SL
(     The third number is the angular order parameter.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CalcAngle)LN
EL
SL
()LN
EL
SL
(REFERENCE)LN
EL
SL
(     Hyberts, SG, Goldberg, MS, Havel, TF, Wagner, G.)LN
EL
SL
(     The solution structure of eglin c based on measurements)LN
EL
SL
(     of many NOEs and coupling constants and its)LN
EL
SL
(     comparison with X-ray structures.)LN
EL
SL
(     Protein Science, 1 \(1992\) 736-751.)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAngle, CheckAco, FigAngles)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960621)LN
EL

