()LN
EL
SL
(NAME)LN
EL
SL
(     AddText - add 3D text annotation)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddText expr string)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add a 3D text annotation. The first argument gives)LN
EL
SL
(     the initial size, the second argument the text.)LN
EL
SL
()LN
EL
SL
(     A label is added for each molecule that has selected)LN
EL
SL
(     atoms. The initial position in space is calculated as)LN
EL
SL
(     the average of the coordinates of all selected atoms)LN
EL
SL
(     of the molecule. It can be moved with the mouse or)LN
EL
SL
(     with the MovePrim command.)LN
EL
SL
()LN
EL
SL
(     For an explanation on how to enter greek letters,)LN
EL
SL
(     sub- and superscript, see the manual page of the)LN
EL
SL
(     EditText command.)LN
EL
SL
()LN
EL
SL
(     The created primitives have the property "text".)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     AddText 0.15 "Label")LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, EditText, ColorPrim, LinePrim,)LN
EL
SL
(     MovePrim, SizeText, AddTitle, RemovePrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970930)LN
EL

