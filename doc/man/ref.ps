SL
()LN
EL
SL
(NAME)LN
EL
SL
(     StartRock - start rock)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     StartRock \( once | cycle \) expr)LN
EL
SL
(         expr expr expr expr expr expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Start to rotate all movable \(set with DialMol\))LN
EL
SL
(     molecules automatically. There are parameters for two)LN
EL
SL
(     phases, so that it is possible to rotate back and)LN
EL
SL
(     forth.)LN
EL
SL
()LN
EL
SL
(     If the first argument is 'once', the movement will)LN
EL
SL
(     only happen once. If it is 'cycle', the program will)LN
EL
SL
(     repeat it until the StopRock command is executed.)LN
EL
SL
()LN
EL
SL
(     The second argument is the minimal delay in)LN
EL
SL
(     milliseconds between rotations. The rest of the)LN
EL
SL
(     arguments are rotation angles for all three axis and)LN
EL
SL
(     number of steps.)LN
EL
SL
()LN
EL
SL
(     It is possible to execute the command while)LN
EL
SL
(     rocking is running, e. g. for changing the delay.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     StartRock cycle 50 0 10 0 18 0 -10 0 18)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     DialMol, StopRock)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     940331)LN
EL

