EL
SL
(     ClipPos - set position of clipping planes)LN
EL
SL
(     ClipSize - set distance of clipping planes)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ClipPos expr)LN
EL
SL
(     ClipSize expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set new values for the distance of the near and)LN
EL
SL
(     far clipping planes. By ClipPos, the user sets)LN
EL
SL
(     the position of the middle between the two)LN
EL
SL
(     planes, by ClipSize the distance:)LN
EL
SL
()LN
EL
SL
(         near = pos - size / 2)LN
EL
SL
(         far  = pos + size / 2)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     ClipPos 8.0)LN
EL
SL
(     ClipSize 5.0)LN
EL
