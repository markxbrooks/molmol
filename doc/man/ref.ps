SL
()LN
EL
SL
(NAME)LN
EL
SL
(     DrawSize - set size of drawing area)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     DrawSize \( set | restore \) [ expr expr ])LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     If the fist argument is 'set', set the size of the)LN
EL
SL
(     drawing are to the given width and height \(in pixels\).)LN
EL
SL
(     This can be useful in connection with plotting, so)LN
EL
SL
(     that the user can enforce a certain aspect ratio for)LN
EL
SL
(     the resulting plot.)LN
EL
SL
()LN
EL
SL
(     With the first argument 'restore', the command)LN
EL
SL
(     restores the drawing area to the last size given with)LN
EL
SL
(     the 'set' option. The saved size is also stored in)LN
EL
SL
(     parameter and dump files, so this command is mainly)LN
EL
SL
(     used for saving a desired window \(and plot\) size in a)LN
EL
SL
(     dump file, and restoring it after reading it back.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     DrawSize set 1000 750)LN
EL
SL
(     DrawSize restore)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPar)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961213)LN
EL

