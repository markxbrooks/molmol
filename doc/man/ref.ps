SL
()LN
EL
SL
(NAME)LN
EL
SL
(     AddSolid - add solid for schematic drawing)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddSolid \( sphere | ellipsoid | cylinder |)LN
EL
SL
(         cone | box \) expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add a solid that \(partly\) covers the selected atoms)LN
EL
SL
(     for each selected molecule. The first parameter)LN
EL
SL
(     selects the desired shape. The second parameter gives)LN
EL
SL
(     the fraction of atoms that must be inside the solid.)LN
EL
SL
()LN
EL
SL
(     The program tries to determine the solid with the)LN
EL
SL
(     smallest volume that covers the desired number of)LN
EL
SL
(     atoms. This is done by a randomized algorithm, so it)LN
EL
SL
(     is possible that the same input parameters do not)LN
EL
SL
(     always lead to exactly the same solid.)LN
EL
SL
()LN
EL
SL
(     The calculation can take up to a few minutes,)LN
EL
SL
(     depending on the shape, the number of atoms, and)LN
EL
SL
(     the coverage.)LN
EL
SL
()LN
EL
SL
(     The created primitives have the property "solid".)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddSolid ellipsoid 0.8)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, ColorPrim, RemovePrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970723)LN
EL

grestore

gsave
/Times-Bold findfont 13837 scalefont setfont

425000 38110 moveto (- 19 -) stringwidth pop 2 div neg 0 rmoveto (- 19 -) show

grestore
