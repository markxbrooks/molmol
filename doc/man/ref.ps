EL
SL
(NAME)LN
EL
SL
(     SizeRibbon - set sizes of ribbons)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     SizeRibbon expr [ expr [ expr [ expr [ expr ] ] ] ])LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the size of all selected ribbons. The first)LN
EL
SL
(     argument gives the width, the second argument the)LN
EL
SL
(     thickness, the third the length of the start part,)LN
EL
SL
(     the fourth the length of the end part and the fifth)LN
EL
SL
(     the width of the arrow as multiple of the ribbon)LN
EL
SL
(     width. Start/end length and arrow width only have an)LN
EL
SL
(     effect if the style is set accordingly \(soft, arrow\).)LN
EL
SL
()LN
EL
SL
(     Entering 0 for any of the sizes will leave this value)LN
EL
SL
(     unchanged. This is useful when one wants to change)LN
EL
SL
(     part of the values for multiple ribbons at once.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     SizeRibbon 3.0 0.5)LN
EL
SL
(     SizeRibbon 2.5 0.4 2.0 2.0 1.4)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddRibbon, SelectPrim, LengthPrim,)LN
EL
SL
(     TypeRibbon, StyleRibbon, PaintRibbon)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950407)LN
EL

