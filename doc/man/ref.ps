SL
()LN
EL
SL
(NAME)LN
EL
SL
(     CalcAtom - calculate missing atom coordinates)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     CalcAtom name)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Calculate coordinates of atoms that were missing )LN
EL
SL
(     in the input file \(e. g. protons in PDB files of)LN
EL
SL
(     crystal structures\).)LN
EL
SL
()LN
EL
SL
(     The command uses the standard geometry from the)LN
EL
SL
(     residue library to calculate the coordinates of)LN
EL
SL
(     the atoms with the given name in all selected)LN
EL
SL
(     residues. If there are not enough known atoms to)LN
EL
SL
(     determine the orientation \(e. g. if only the O)LN
EL
SL
(     of a water is given\), the program will choose a)LN
EL
SL
(     random orientation. Atom oordinates that are)LN
EL
SL
(     known already will not be changed.)LN
EL
SL
()LN
EL
SL
(     The name can contain wildcards \(?, *\).)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CalcAtom "H*")LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectRes, AddAtom)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     951110)LN
EL

