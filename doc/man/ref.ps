()LN
EL
SL
(NAME)LN
EL
SL
(     AttrAtom - list attributes of atoms)LN
EL
SL
(     AttrBond - list attributes of bonds)LN
EL
SL
(     AttrDist - list attributes of distances)LN
EL
SL
(     AttrPrim - list attributes of primitives)LN
EL
SL
(     AttrInit - list initial attributes)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AttrAtom)LN
EL
SL
(     AttrBond)LN
EL
SL
(     AttrDist)LN
EL
SL
(     AttrPrim)LN
EL
SL
(     AttrInit)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     The first four commands list the values of the)LN
EL
SL
(     attributes of all selected atoms, bonds, distances)LN
EL
SL
(     or primitives. All items have to share the same set)LN
EL
SL
(     of attributes, an error message is issued otherwise.)LN
EL
SL
()LN
EL
SL
(     AttrInit lists the values of the initial attributes)LN
EL
SL
(     used for new objects.)LN
EL
SL
()LN
EL
SL
(     Also creates a macro that can be used to set all)LN
EL
SL
(     the attributes to these values.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     AttrAtom)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     Select*, Color*, Material*, Texture*, Style*, Line*)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     991016)LN
EL

