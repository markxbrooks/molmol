()LN
EL
SL
(NAME)LN
EL
SL
(     AddTitle - add 2D text annotation)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddTitle <coord> expr string)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add a text annotation at a given screen position.)LN
EL
SL
(     The screen position must be entered by a mouse click)LN
EL
SL
(     or on the command line. The second argument is the)LN
EL
SL
(     size, the third the string to be displayed.)LN
EL
SL
()LN
EL
SL
(     The origin of the screen coordinates is at the center)LN
EL
SL
(     of the window. The x-axis runs from left to right,)LN
EL
SL
(     the y-axis from bottom to top. The range for y is)LN
EL
SL
(     -1.0 to 1.0, the one for x depends on the aspect)LN
EL
SL
(     ratio, e. g. it would be -1.5 to 1.5 if the window)LN
EL
SL
(     width is 50% larger than the window height.)LN
EL
SL
()LN
EL
SL
(     For an explanation on how to enter greek letters,)LN
EL
SL
(     sub- and superscript, see the manual page of the)LN
EL
SL
(     EditText command.)LN
EL
SL
()LN
EL
SL
(     The created primitives have the properties "text")LN
EL
SL
(     and "title".)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     AddTitle 0.5 0.3 0.15 "Label")LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     EditText, ColorPrim, LinePrim, MovePrim, SizeText,)LN
EL
SL
(     AddText, RemovePrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970723)LN
EL

