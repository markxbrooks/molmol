EL
SL
(NAME)LN
EL
SL
(     UndefProp - undefine property)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     UndefProp propertyName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Undefine the property with the given name everywhere.)LN
EL
SL
(     This command is rarely used. The program cannot detect)LN
EL
SL
(     if a property is not used anymore. Executing this)LN
EL
SL
(     command with unused properties can help to avoid)LN
EL
SL
(     problems \(like unnecessarily large dump files or)LN
EL
SL
(     overflow of internal tables\), especially when a lot)LN
EL
SL
(     of different properties are used.)LN
EL
SL
()LN
EL
SL
(     The number of different properties supported by the)LN
EL
SL
(     program is currently set to 2048.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     UndefProp bb)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     DefProp*)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     940408)LN
EL

