()LN
EL
SL
(NAME)LN
EL
SL
(     WriteLib - write entries for residue library)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     WriteLib fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     For all selected residues that were not in the residue)LN
EL
SL
(     library or that were modified by commands like AddAtom)LN
EL
SL
(     and AddBond, write an entry for the residue library)LN
EL
SL
(     into the given file.)LN
EL
SL
()LN
EL
SL
(     For working with non-standard residues, the best)LN
EL
SL
(     strategy is:)LN
EL
SL
()LN
EL
SL
(         1. Read a structure that contains the residue.)LN
EL
SL
()LN
EL
SL
(         2. Define bonds with the commands CalcBond,)LN
EL
SL
(            AddBond and RemoveBond, use AddAtom, RemoveAtom)LN
EL
SL
(            and AddPseudo if necessary.)LN
EL
SL
()LN
EL
SL
(         3. Define angles with AddAngle.)LN
EL
SL
()LN
EL
SL
(         4. WriteLib xxx.lib.)LN
EL
SL
()LN
EL
SL
(         5. Edit xxx.lib if necessary \(e. g. the atom)LN
EL
SL
(            types\).)LN
EL
SL
()LN
EL
SL
(         6. Make a copy of the standard library)LN
EL
SL
(            \($MOLMOLHOME/setup/amber94.lib\) and append)LN
EL
SL
(            xxx.lib.)LN
EL
SL
()LN
EL
SL
(         7. InitAll.)LN
EL
SL
()LN
EL
SL
(         8. Use PathNames to set name of new library.)LN
EL
SL
()LN
EL
SL
(         9. Check the library by executing the command)LN
EL
SL
(            ReadLib.)LN
EL
SL
()LN
EL
SL
(        10. Read structure.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     WriteLib /home/joe/my_res.lib)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddAtom, AddPseudo, RemoveAtom, CalcBond, CheckBond,)LN
EL
SL
(     AddBond, RemoveBond, AddAngle, RemoveAngle,)LN
EL
SL
(     InitAll, PathNames, ReadLib)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980303)LN
EL

