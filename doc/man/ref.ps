()LN
EL
SL
(NAME)LN
EL
SL
(     AddAngle - add dihedral angle)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddAngle name)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add a dihedral angle with the given name, defined)LN
EL
SL
(     by the four selected atoms. Exactly four atoms must)LN
EL
SL
(     be selected before this command is executed, an error)LN
EL
SL
(     message will be issued otherwise.)LN
EL
SL
()LN
EL
SL
(     Two of the atoms must be from the same residue, one)LN
EL
SL
(     also from the same residue or the previous residue,)LN
EL
SL
(     one from the same residue or the next residue.)LN
EL
SL
()LN
EL
SL
(     The name must be unique within the residue.)LN
EL
SL
()LN
EL
SL
(     The new angle cannot be used immediately for commands)LN
EL
SL
(     like RotateAngle, only angles that were in the residue)LN
EL
SL
(     library can be used for that purpose. The command is)LN
EL
SL
(     intended to be used in conjunction with WriteRes to)LN
EL
SL
(     generate library entries for non-standard residues.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddAngle "RHO")LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddAtom, AddBond, CalcBond, WriteLib)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961219)LN
EL

grestore

gsave
/Times-Bold findfont 13837 scalefont setfont

