()LN
EL
SL
(NAME)LN
EL
SL
(     SetNeigh - set sheet neighbours of residues)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     SetNeigh expr expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the information about neighbouring residues used)LN
EL
SL
(     for schematic display of beta sheets. The arguments)LN
EL
SL
(     are applied to all selected molecules.)LN
EL
SL
()LN
EL
SL
(     The first and second argument give the numbers of the)LN
EL
SL
(     start and end residues in the first strand, where the)LN
EL
SL
(     start number must be smaller than the end number. The)LN
EL
SL
(     third and fourth argument give the start and end)LN
EL
SL
(     numbers of residues in the second strand. For a)LN
EL
SL
(     parallel pair of strands, the start number must be)LN
EL
SL
(     smaller than the end number, for an antiparallel pair)LN
EL
SL
(     it must be larger. Both strands must have the same)LN
EL
SL
(     number of residues and must not overlap.)LN
EL
SL
()LN
EL
SL
(     This command is only used if the secondary structure)LN
EL
SL
(     information was not read from a PDB file or calculated)LN
EL
SL
(     with CalcSecondary, or if the user wants to modify)LN
EL
SL
(     this information.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     SetNeigh 18 24 35 29)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadPdb, CalcSecondary, WriteSecondary,)LN
EL
SL
(     AddRibbon, TypeRibbon)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950523)LN
EL

