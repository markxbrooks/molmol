(NAME)LN
EL
SL
(     RecordMac - open macro recorder)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     RecordMac)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Open a macro recorder. The text area shows the macro)LN
EL
SL
(     recorded so far, it can also be edited manually.)LN
EL
SL
(     The 'Add' button adds the most recently executed)LN
EL
SL
(     commands, the number of commands is given in the)LN
EL
SL
(     text field. If 'automatic' is switched on, each)LN
EL
SL
(     executed command is recorded automatically.)LN
EL
SL
()LN
EL
SL
(     The 'Test' button executes the recorded macro, the)LN
EL
SL
(     'Save' button stores it with the given file name.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     RecordMac)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     XMacUser)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950626)LN
EL

