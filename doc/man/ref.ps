EL
SL
(NAME)LN
EL
SL
(     LengthPrim - set length of primitives)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     LengthPrim expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the length of all selected ribbons. The first)LN
EL
SL
(     argument gives the start parameter, the second)LN
EL
SL
(     argument the end parameter. The parameter value is )LN
EL
SL
(     1 for the first atom used for AddRibbon, 2 for the)LN
EL
SL
(     second atom, etc.)LN
EL
SL
()LN
EL
SL
(     The command can also be used for changing the)LN
EL
SL
(     length of a cylinder. In this case, the parameter)LN
EL
SL
(     range 0 to 1 refers to the current size of the)LN
EL
SL
(     cylinder, and the new parameter values are interpreted)LN
EL
SL
(     relative to these values.)LN
EL
SL
()LN
EL
SL
(     Entering 0 for any of the parameters will leave this)LN
EL
SL
(     value unchanged.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     LengthPrim 12.5 20.5)LN
EL
SL
(     LengthPrim 0.1 1.1)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddRibbon, SelectPrim, MovePrim,)LN
EL
SL
(     TypeRibbon, StyleRibbon, SizeRibbon, PaintRibbon)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     951123)LN
EL

