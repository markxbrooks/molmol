SL
(NAME)LN
EL
SL
(     FigCircles - show angle distribution circles)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     FigCircles expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Create a figure showing the angle distributions as)LN
EL
SL
(     polylines inside circles. The first argument gives the)LN
EL
SL
(     number of rows over which the circles are distributed,)LN
EL
SL
(     the second argument is the font size relative to the)LN
EL
SL
(     radius of the circles.)LN
EL
SL
()LN
EL
SL
(     The same number of angles has to be selected in all)LN
EL
SL
(     selected molecules, the corresponding angles from all)LN
EL
SL
(     molecules will be drawn in one circle, from the inside)LN
EL
SL
(     to the outside. 0 is at the top, 90 degrees at the)LN
EL
SL
(     right side of the circle.)LN
EL
SL
()LN
EL
SL
(     This kind of figure is mainly used for analyzing)LN
EL
SL
(     results of MD runs.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     FigCircles 4 0.3)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, SelectAngle, Group, FigOff, FigAngles)LN
EL
