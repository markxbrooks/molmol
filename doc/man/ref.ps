()LN
EL
SL
(NAME)LN
EL
SL
(     DrawPrec - set drawing precision)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     DrawPrec expr [ expr ])LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the precision for certain drawing operations,)LN
EL
SL
(     e. g. for the approximation of spheres. Making this)LN
EL
SL
(     value larger improves the drawing quality, but makes)LN
EL
SL
(     the drawing slower. Reasonable values are in the range)LN
EL
SL
(     between 2 \(moderate quality\) and 4 \(good quality\).)LN
EL
SL
()LN
EL
SL
(     The optional second argument is used as precision)LN
EL
SL
(     during interactive manipulations \(rotating, moving\).)LN
EL
SL
(     It can be chosen smaller to make these manipulations)LN
EL
SL
(     smoother, at the cost of lower drawing quality.)LN
EL
SL
()LN
EL
SL
(     The value used for plotting can be set seperately with)LN
EL
SL
(     the PlotPar command.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     DrawPrec 3)LN
EL
SL
(     DrawPrec 4 2)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPar)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980818)LN
EL

grestore

