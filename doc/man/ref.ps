()LN
EL
SL
(NAME)LN
EL
SL
(     TrimSurface - cut away part of a surface)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     TrimSurface expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Cut away part of all selected surfaces. The part that)LN
EL
SL
(     is trimmed off is given by the selected atoms, all)LN
EL
SL
(     surface parts that have a distance smaller than the)LN
EL
SL
(     value given as argument from a selected atom are cut)LN
EL
SL
(     away. The distance from an atom takes the VdW radius)LN
EL
SL
(     into account, the argument is an additional offset.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     TrimSurface 1.0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectPrim, AddSurface, NearPrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970718)LN
EL

