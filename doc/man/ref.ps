SL
()LN
EL
SL
(NAME)LN
EL
SL
(     CalcAxis - calculate lengths of principal axes)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     CalcAxis \( 0 | 1 \) \( 0 | 1 \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Generate a report with the relative lengths of the)LN
EL
SL
(     principal axes of all selected molecules. Only the)LN
EL
SL
(     selected atoms of each molecule are used, the same)LN
EL
SL
(     mass is used for all atoms.)LN
EL
SL
()LN
EL
SL
(     The lengths are listed relatively to the shortest axis,)LN
EL
SL
(     the average for all structures is given at the end.)LN
EL
SL
()LN
EL
SL
(     The first option selects whether a list with the angles)LN
EL
SL
(     of all selected bonds relative to the principal axes)LN
EL
SL
(     should be printed.)LN
EL
SL
()LN
EL
SL
(     The second option selects whether the principal axes)LN
EL
SL
(     should be displayed. A cylinder will be added, it can)LN
EL
SL
(     be manipulated with the corresponding commands, like)LN
EL
SL
(     LengthPrim and RadiusPrim. The created primitives have)LN
EL
SL
(     the properties "axis" and "cylinder".)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CalcAxis 0 1)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, Group, Fit,  ColorPrim, LengthPrim,)LN
EL
SL
(     RemovePrim, AddCylinder)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     9991106)LN
EL

