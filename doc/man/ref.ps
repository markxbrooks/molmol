(NAME)LN
EL
SL
(     DrawDelay - set drawing delay)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     DrawDelay expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set a delay for drawing. The program will pause)LN
EL
SL
(     for the given time \(in milliseconds\) after each)LN
EL
SL
(     redraw. This can be useful on machines without)LN
EL
SL
(     double buffering, to avoid too much flickering.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     DrawDelay 100)LN
EL
SL
()LN
EL
SL
