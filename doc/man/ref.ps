SL
(     and the molecules have to be read again. Just leaving)LN
EL
SL
(     the program and starting it again does not help, since)LN
EL
SL
(     the contents is stored in the molmol/dump file in the)LN
EL
SL
(     home directory. PropDef is handled in the same way.)LN
EL
SL
()LN
EL
SL
(     If the file with the given path name cannot be)LN
EL
SL
(     openend, the program will silently fall back to the)LN
EL
SL
(     default file.)LN
EL
SL
()LN
EL
SL
(     The special name "0" can be given for path names,)LN
EL
SL
(     in this case an empty file will be taken for the)LN
EL
SL
(     corresponding configuration file. This can be handy)LN
EL
SL
(     e. g. for PdbAtoms when you want to read a PDB file)LN
EL
SL
(     without using the normal translation for atom names.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PathNames "" "" "" "" "" "" "/home/joe/molmol/my.lib" "" "")LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     CalcBond, FlipAtom, CalcShift, ReadPdb, DialColor,)LN
EL
SL
