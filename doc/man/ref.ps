EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     TintDist expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the secondary color of all selected distances.)LN
EL
SL
(     The color is given by its Red, Green and Blue)LN
EL
SL
(     component, all in the range between 0.0 and 1.0.)LN
EL
SL
()LN
EL
SL
(     The secondary color is used to show the size of the)LN
EL
SL
(     violation for distance constraints if this display)LN
EL
SL
(     style is selected with StyleDist.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     TintDist 1.0 0.0 0.0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectDist, StyleDist, ColorDist, DialColor, TintInit)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950407)LN
EL

