EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Change the name of all selected molecules. When)LN
EL
SL
(     multiple molecules are renamed, they can be given)LN
EL
SL
(     unique names by appending a number to the name.)LN
EL
SL
(     )LN
EL
SL
(     The first argument gives the \(base\) name, the second)LN
EL
SL
(     one the starting number for numbering molecules, the)LN
EL
SL
(     third one the number of digits for numbering.)LN
EL
SL
()LN
EL
SL
(     When changing the name of only one molecule, the)LN
EL
SL
(     number of digits \(third argument\) should be 0, so that)LN
EL
SL
(     the name given as first argument is directly used as)LN
EL
SL
(     name.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     NameMol bpti 1 0)LN
EL
SL
(     NameMol bpti 21 3)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     NewMol, DialMol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980319)LN
EL

