(NAME)LN
EL
SL
(     AddAco - add angle constraints)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddAco expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add an angle constraint for all selected angles.)LN
EL
SL
(     The first argument gives the minimal value, the)LN
EL
SL
(     second the maximal value in degrees.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddAco -20 130)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadAco, SelectAngle, RemoveAco, AddUpl, AddLol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950302)LN
EL

