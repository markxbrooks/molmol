()LN
EL
SL
(NAME)LN
EL
SL
(     DialMeasure - switch measurement dialog on and off)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     DialMeasure \( off | on \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Switch measurement dialog on and off.)LN
EL
SL
(     )LN
EL
SL
(     The measurement dialog displays bond lengths, bond)LN
EL
SL
(     angles, atom distances and dihedral angles of)LN
EL
SL
(     interactively selected atoms, bonds and angles.)LN
EL
SL
()LN
EL
SL
(     The top line of the dialogs reflects the bond and atom)LN
EL
SL
(     selections that are used for the measurements. All)LN
EL
SL
(     other lines correspond to one measurement, where the)LN
EL
SL
(     left text field shows the bond\(s\)/atoms involved, and)LN
EL
SL
(     the result of the measurement \(distance or angle\) is)LN
EL
SL
(     displayed in the right text field.)LN
EL
SL
()LN
EL
SL
(     The "Bond Length" line displays the length of the most)LN
EL
SL
(     recently selected bond.)LN
EL
SL
()LN
EL
SL
(     The "Bond Angle" line displays the angle between the)LN
EL
SL
(     two most recently selected bonds.)LN
EL
SL
()LN
EL
SL
(     The "Bond Dih." line displays the dihedral angle)LN
EL
SL
(     between the three most recently selected bonds.)LN
EL
SL
()LN
EL
SL
(     The "Atom Dist." line displays the distance between)LN
EL
SL
(     the two most recently selected atoms.)LN
EL
SL
()LN
EL
SL
(     The "Atom Angle" line displays the angle defined by)LN
EL
SL
(     the three most recently selected atoms.)LN
EL
SL
()LN
EL
SL
(     The "Atom Dih." line displays the angle defined by the)LN
EL
SL
(     four most recently selected atoms.)LN
EL
SL
()LN
EL
SL
(     The OK button closes the dialog, the Help button shows)LN
EL
SL
(     this help page.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     DialMeasure on)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddDist, WriteAng)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980409)LN
EL

