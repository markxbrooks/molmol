(NAME)LN
EL
SL
(     RadiusPrim - set radius of primitives)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     RadiusPrim expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the radius used for drawing all selected)LN
EL
SL
(     primitives. If the radius of a spline is set to 0,)LN
EL
SL
(     the spline is drawn as line, otherwise it is drawn)LN
EL
SL
(     as tube with the given radius.)LN
EL
