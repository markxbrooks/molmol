()LN
EL
SL
(NAME)LN
EL
SL
(     RotateAngle - rotate dihedral angles)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     RotateAngle expr { expr })LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Rotate all selected dihedral angles. The first)LN
EL
SL
(     argument gives the number of angles that should rotate)LN
EL
SL
(     the chain backwards \(i. e. towards the N-terminus in a)LN
EL
SL
(     protein\). The user will normally not enter the value)LN
EL
SL
(     of the angles on the command line, but use the dialog)LN
EL
SL
(     box to interactively vary the angles.)LN
EL
SL
()LN
EL
SL
(     If backwards rotation is desired, the first argument)LN
EL
SL
(     should be adjusted *before* any of the angles are)LN
EL
SL
(     modified, otherwise it will not have the desired)LN
EL
SL
(     effect.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     RotateAngle 1 -57.0 -47.0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAngle, SetAngle)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     951208)LN
EL

