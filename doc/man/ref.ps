(     LabelAtom - set format of atom label)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     LabelAtom string)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the format of the label of all selected atoms.)LN
EL
SL
(     If the character 'R' appears in the string, it is)LN
EL
SL
(     replaced by the residue name. 'N' is replace by the)LN
EL
SL
(     residue number, 'A' by the atom name. All other)LN
EL
SL
(     characters are displayed in the label unchanged.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     LabelAtom "R N")LN
EL
SL
()LN
EL
SL
