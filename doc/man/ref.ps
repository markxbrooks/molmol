(NAME)LN
EL
SL
(     WriteLol - write file with lower limits)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     WriteLol fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Write a file with lower distance limits. The format is)LN
EL
SL
(     the same that DIANA/DYANA uses. All selected lower)LN
EL
SL
(     distance limits are written. When a constraint between)LN
EL
SL
(     two atoms appears in more than one molecule, the)LN
EL
SL
(     largest constraint value is written.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     WriteLol /home/joe/struct/my_prot.lol)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, Group, ReadLol, AddLol, CheckLol, WriteUpl)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980326)LN
EL

