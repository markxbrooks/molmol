()LN
EL
SL
(NAME)LN
EL
SL
(     Stereo - set stereo mode)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     Stereo \( off | left | right | side_by_side |)LN
EL
SL
(         cross_eye | hardware \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set stereo mode. Hardware stereo is not supported by)LN
EL
SL
(     all hardware. If it is supported, it normally works)LN
EL
SL
(     only in fullscreen mode \(see command Fullscreen\).)LN
EL
SL
()LN
EL
SL
(     Hardware stereo is also supported for certain plot)LN
EL
SL
(     devices. E. g. generating a PostScript plot in)LN
EL
SL
(     hardware stereo mode will produce a side by side)LN
EL
SL
(     stereo image with the correct eye distance, while)LN
EL
SL
(     the distance between the images will very likely)LN
EL
SL
(     be wrong when plotting in side_by_side mode.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Stereo side_by_side)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     Fullscreen)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     941205)LN
EL

