SL
()LN
EL
SL
(     ReplaceListPdb expects a file with one file name per)LN
EL
SL
(     line \(empty lines allowed\), and reads coordinates)LN
EL
SL
(     from all these files, replacing the coordinates of)LN
EL
SL
(     the selected molecules.)LN
EL
SL
()LN
EL
SL
(     See ReadPdb for more information about the PDB format.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
