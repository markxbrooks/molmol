()LN
EL
SL
(NAME)LN
EL
SL
(     BondMode - choose bond display mode)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     BondMode \( normal | pseudo \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Choose whether the regular bonds or bonds to pseudo)LN
EL
SL
(     atoms are displayed. This is a global switch, it is)LN
EL
SL
(     currently not possible to change this for individual)LN
EL
SL
(     bonds.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     BondMode pseudo)LN
EL
SL
()LN
EL
SL
(WARNING)LN
EL
SL
(     Rings look somewhat weird in 'pseudo' mode.)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950606)LN
EL

