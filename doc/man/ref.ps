()LN
EL
SL
(NAME)LN
EL
SL
(     Group - define molecule groups)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     Group expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Define groups with the currently selected molecules.)LN
EL
SL
(     The argument gives the number of members of each)LN
EL
SL
(     group. The default value is all selected molecules.)LN
EL
SL
(     If a smaller number is given, multiple groups with)LN
EL
SL
(     the desired number of molecules each are defined.)LN
EL
SL
(     E. g. the value 2 will make a group with the first)LN
EL
SL
(     and second selected molecule, another one with the)LN
EL
SL
(     third and fourth, etc.)LN
EL
SL
()LN
EL
SL
(     Defining groups changes the behaviour of a number)LN
EL
SL
(     of commands, mostly the ones for calculation. They)LN
EL
SL
(     will treat the molecules in a group as if they were)LN
EL
SL
(     only one molecule. This is commonly used when dealing)LN
EL
SL
(     with complexes, so that e. g. CalcSurface will)LN
EL
SL
(     calculate the surface of the whole complex, and not)LN
EL
SL
(     of each molecule individually.)LN
EL
SL
()LN
EL
SL
(     The help page of every command that deals with groups)LN
EL
SL
(     has the remark "this command supports groups" at the)LN
EL
SL
(     bottom.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Group 2)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960317)LN
EL

