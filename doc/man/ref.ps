SL
()LN
EL
SL
(NAME)LN
EL
SL
(     Fog - setup of fog \(depth cueing\))LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     Fog \( off | exp | exp2 | linear \) expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set fog mode and parameters. The first argument)LN
EL
SL
(     selects the mode \(off, exponential, squared)LN
EL
SL
(     exponential, linear\). The second argument selects the)LN
EL
SL
(     density for both kinds of exponential fog. The third)LN
EL
SL
(     and fourth argument give the start and end distance)LN
EL
SL
(     for linear fog.)LN
EL
SL
()LN
EL
SL
(     Negative values for any of the numerical arguments)LN
EL
SL
(     will leave the value unchanged, this is useful for)LN
EL
SL
(     changing only one value if the command is put on a)LN
EL
SL
(     slider.)LN
EL
SL
()LN
EL
SL
(     Not all fog modes are supported on all hardware.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Fog linear 0.1 7.0 13.0)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960305)LN
EL

