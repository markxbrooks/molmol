()LN
EL
SL
(NAME)LN
EL
SL
(     PlotPov - make a POV-Ray plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotPov fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Make a plot of the current screen contents in POV-Ray)LN
EL
SL
(     format. This can be used as input file for the ray)LN
EL
SL
(     tracing package POV-Ray \(Persistence of Vision Ray)LN
EL
SL
(     Tracer\) to produce high quality pictures.)LN
EL
SL
()LN
EL
SL
(     The POV-Ray software is available free of charge by)LN
EL
SL
(     anonymous ftp from ftp.povray.org, directory)LN
EL
SL
(     /pub/povray/Official. See the accompanying files for)LN
EL
SL
(     copyright conditions and instructions on installation)LN
EL
SL
(     and use of the program. The output files generally)LN
EL
SL
(     have to be rendered with version 3.0 \(or higher\) of)LN
EL
SL
(     POV-Ray. If certain features, like text, are not)LN
EL
SL
(     used, they may also work with POV-Ray 2.2, but this)LN
EL
SL
(     is not supported.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotPov /home/joe/MyPlot.pov)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotFm*, PlotPs, PlotTiff, PlotJpeg, PlotPng,)LN
EL
SL
(     PlotVrml1, PlotVrml2)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961204)LN
EL

