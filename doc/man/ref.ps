()LN
EL
SL
(NAME)LN
EL
SL
(     PlotBmp - make a BMP \(Windows bitmap\) plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotBmp fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Save the current screen contents as BMP file, the)LN
EL
SL
(     standard image file format used on Windows. The)LN
EL
SL
(     horizontal resolution can be set with the PlotPar)LN
EL
SL
(     command, the vertical resolution is calculated to)LN
EL
SL
(     maintain the aspect ratio of the screen.)LN
EL
SL
()LN
EL
SL
(     This command is not supported on all machines and)LN
EL
SL
(     with all graphics systems. It will give an appropriate)LN
EL
SL
(     error message if it is not supported.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotBmp /home/joe/MyPlot.bmp)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPar, PlotTiff, PlotJpeg, PlotPng)LN
EL
SL
(     PlotFm3, PlotFm4, PlotPs)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970225)LN
EL

