()LN
EL
SL
(NAME)LN
EL
SL
(     FigContact - show contact map)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     FigContact name name name name expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Create a figure showing a contact map of residues. The)LN
EL
SL
(     first argument gives a property name, the residues)LN
EL
SL
(     with this property set will be shown on the horizontal)LN
EL
SL
(     axis. The residues with the property given as second)LN
EL
SL
(     argument will be shown on the vertical axis.)LN
EL
SL
()LN
EL
SL
(     For each of these residues, only the atoms with the)LN
EL
SL
(     property given as third argument will be considered)LN
EL
SL
(     for the contacts shown on the top-left side of the)LN
EL
SL
(     diagonal, the ones with the property given as fourth)LN
EL
SL
(     argument will be considered for the bottom-right side)LN
EL
SL
(     of the diagonal.)LN
EL
SL
()LN
EL
SL
(     Two distances are given as fifth and sixth argument.)LN
EL
SL
(     Nothing will be drawn if the smallest distance between)LN
EL
SL
(     two atoms of the corresponding residues is larger than)LN
EL
SL
(     the maximal distance. A black square will be drawn if)LN
EL
SL
(     it is smaller than the minimal distance. Values in)LN
EL
SL
(     between are shown with increasing levels of grey.)LN
EL
SL
()LN
EL
SL
(     If more than one molecule is selected, they all need)LN
EL
SL
(     to have the same structure. The distance of each atom)LN
EL
SL
(     pair is calculated as average over the distances in)LN
EL
SL
(     each individual molecule. So what is used for the plot)LN
EL
SL
(     is the minimal average distance of atom pairs between)LN
EL
SL
(     the corresponding residues.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     FigContact 'selected' 'selected' 'bb' 'all' 3.0 5.0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     DefPropRes, DefPropAtom, Group, FigOff,)LN
EL
SL
(     FigLimit, CalcDist)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961126)LN
EL

