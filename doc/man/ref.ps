EL
SL
(NAME)LN
EL
SL
(     FigDist - show distance vs. structure number)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     FigDist expr expr expr \( 0 | 1 \) \( 0 | 1 \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Create a figure showing distances on the vertical axis)LN
EL
SL
(     vs. structure numbers on the horizontal axis. The first)LN
EL
SL
(     argument gives the number of rows over which the plots)LN
EL
SL
(     are distributed.)LN
EL
SL
()LN
EL
SL
(     The second and third argument give the distance range)LN
EL
SL
(     on the vertical axis.)LN
EL
SL
()LN
EL
SL
(     A plot will be made for all selected distances of the)LN
EL
SL
(     first selected molecule, the corresponding distances)LN
EL
SL
(     from all selected molecules will be shown.)LN
EL
SL
()LN
EL
SL
(     The first option selects whether residue numbers are)LN
EL
SL
(     written as subscripts. The second option selects)LN
EL
SL
(     whether the values of constraints are shown as)LN
EL
SL
(     horizontal lines.)LN
EL
SL
()LN
EL
SL
(     This kind of figure is mainly used for analyzing)LN
EL
SL
(     results of MD runs.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     FigDist 4 3.0 7.0 0 1)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, SelectDist, Group, FigOff,)LN
EL
SL
(     FigAngles, FigCircles)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960317)LN
EL

