()LN
EL
SL
(NAME)LN
EL
SL
(     UserInterface - switch elements of user interface)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     UserInterface \( 0 | 1 \) \( 0 | 1 \) \( 0 | 1 \))LN
EL
SL
(         \( 0 | 1 \) \( 0 | 1 \) \( 0 | 1 \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Switch various parts of the user interface on or)LN
EL
SL
(     off. The following elements can be switched:)LN
EL
SL
()LN
EL
SL
(         Valuator Box)LN
EL
SL
(         Log Window)LN
EL
SL
(         Buttons)LN
EL
SL
(         Command Line)LN
EL
SL
(         Status Line)LN
EL
SL
(         Menubar)LN
EL
SL
()LN
EL
SL
(     The program makes sure that Command Line and)LN
EL
SL
(     Menubar are not switched off at the same time,)LN
EL
SL
(     because this would make it impossible to enter)LN
EL
SL
(     any more commands.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     UserInterface 0 0 1 1 1 1)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     940818)LN
EL

