SL
()LN
EL
SL
(NAME)LN
EL
SL
(     CalcMatch - calculate best matching structure parts)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     CalcMatch expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Determines which parts of all selected molecules can)LN
EL
SL
(     be superimposed with the smallest RMSD, taking into)LN
EL
SL
(     account all selected atoms of all selected residues.)LN
EL
SL
(     The structures do not need to be identical, but the)LN
EL
SL
(     same number of residues with the same number of atoms)LN
EL
SL
(     each must be selected. The structures do not need to)LN
EL
SL
(     be superimposed before executing the command.)LN
EL
SL
()LN
EL
SL
(     The first argument gives the minimal number of)LN
EL
SL
(     residues that must be superimposed, the second)LN
EL
SL
(     argument the maximal RMSD \(to the mean\) desired.)LN
EL
SL
()LN
EL
SL
(     The algorithm is relatively simple, it superimposes)LN
EL
SL
(     the structures with the current set of atoms \(starting)LN
EL
SL
(     with all selected ones\), and in each step it leaves)LN
EL
SL
(     away the atoms from the residue that has the largest)LN
EL
SL
(     global displacement. This is repeated until one of)LN
EL
SL
(     the conditions given by the arguments is met.)LN
EL
SL
()LN
EL
SL
(     A protocol of the progress, giving RMSD and largest)LN
EL
SL
(     displacement, is printed. All values are to the mean.)LN
EL
SL
(     At the end, an expression for selecting the)LN
EL
SL
(     superimposed residues for each molecule is printed.)LN
EL
SL
(     The property "match" is set on all these residues.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CalcMatch 50 0.7)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, SelectAtom, Group, Fit, CalcRmsd)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960323)LN
EL

grestore

