()LN
EL
SL
(NAME)LN
EL
SL
(     PlotFm3 - make a FrameMaker 3 plot)LN
EL
SL
(     PlotFm4 - make a FrameMaker 4 plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotFm3 fileName)LN
EL
SL
(     PlotFm4 fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Make a plot of the current screen contents in MIF)LN
EL
SL
(     format. This can be imported into FrameMaker.)LN
EL
SL
()LN
EL
SL
(     PlotFm3 produces a file that can be read by)LN
EL
SL
(     FrameMaker 3 or later. This only supports 8)LN
EL
SL
(     different colors, and is therefore not suited for)LN
EL
SL
(     displays with shading. Its main use is for the)LN
EL
SL
(     output of figures from commands like FigAngles.)LN
EL
SL
()LN
EL
SL
(     PlotFm4 makes use of color possibilities introduced)LN
EL
SL
(     in FrameMaker 4, these files cannot be read by)LN
EL
SL
(     earlier versions. They are also larger.)LN
EL
SL
()LN
EL
SL
(     FrameMaker can currently not handle the files created)LN
EL
SL
(     with PlotFm4 well, they make it very slow. Unless this)LN
EL
SL
(     improves with future versions, PlotFm4 is only of)LN
EL
SL
(     limited usefulness.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotFm4 /home/joe/MyPlot.fm)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPar, PlotPs)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950704)LN
EL

