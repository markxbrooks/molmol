()LN
EL
SL
(NAME)LN
EL
SL
(     ReadShift - read file with chemical shifts)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadShift fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read a file with chemical shifts. Both the old and)LN
EL
SL
(     new formats used by EASY/XEASY can be read.)LN
EL
SL
()LN
EL
SL
(     The old format is:)LN
EL
SL
(         columns  1- 4: proton number)LN
EL
SL
(         columns  6-12: shift)LN
EL
SL
(         columns 33-37: atom name)LN
EL
SL
(         columns 38-42: residue number)LN
EL
SL
()LN
EL
SL
(     The new format is:)LN
EL
SL
(         columns  1- 4: proton number)LN
EL
SL
(         columns  6-12: shift)LN
EL
SL
(         columns 20-24: atom name)LN
EL
SL
(         columns 25-28: residue number)LN
EL
SL
()LN
EL
SL
(     The chemical shifts are added to all selected)LN
EL
SL
(     molecules.)LN
EL
SL
()LN
EL
SL
(     The chemical shifts can be used in expressions,)LN
EL
SL
(     e. g. for selection. The program can also generate)LN
EL
SL
(     an expected NOESY peak list with the command CalcDist.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadShift /home/joe/struct/my_prot.prot)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     DialMol, SelectMol, CalcDist)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950810)LN
EL

