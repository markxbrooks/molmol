()LN
EL
SL
(NAME)LN
EL
SL
(     StartAnim - start animation)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     StartAnim \( once | cycle \) expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Start an animation. This can be used for displaying)LN
EL
SL
(     MD runs. If the first argument is 'once', every)LN
EL
SL
(     selected structure will be displayed once.)LN
EL
SL
()LN
EL
SL
(     If it is 'cycle', the program will loop through all)LN
EL
SL
(     selected structures until the StopAnim command is)LN
EL
SL
(     executed.)LN
EL
SL
()LN
EL
SL
(     The second argument is the minimal delay in)LN
EL
SL
(     milliseconds between displaying structures.)LN
EL
SL
()LN
EL
SL
(     It is possible to execute the command while an)LN
EL
SL
(     animation is running, e. g. for changing the delay.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     StartAnim cycle 50)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, DialMol, StopAnim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     940216)LN
EL

