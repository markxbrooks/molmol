SL
(     the two.)LN
EL
SL
()LN
EL
SL
(     For correct results, special care should be taken)LN
EL
SL
(     that the residue definitions with the correct)LN
EL
SL
(     charges are used. This is expecially important when)LN
EL
SL
(     using PDB files, because the residue names in there)LN
EL
SL
(     normally do not contain the charges. There is a)LN
EL
SL
(     standard macro called pdb_charge.mac that can be)LN
EL
SL
(     run after reading PDB files, it should normally do)LN
EL
SL
(     the necessary corrections. For the N and C termini,)LN
EL
SL
(     the molecules should have charged end groups, or)LN
EL
SL
(     special forms of the residues that contain the)LN
EL
SL
(     necessary charges.)LN
EL
SL
()LN
EL
SL
(     Depending on the precision, this function can use)LN
EL
SL
(     a lot of memory, an error message will be given)LN
EL
SL
(     if the memory runs out.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CalcPot vdw charge 2.0 80.0 1.4 0.3 2.0)LN
EL
SL
(         10.0 zero foo.pot)LN
EL
SL
()LN
EL
SL
(REFERENCE)LN
EL
SL
(     Nicholls, A, Honig, B.)LN
EL
SL
(     A rapid finite difference algorithm, utilizing)LN
EL
SL
(     successive over-relaxation to solve the)LN
EL
SL
(     Poisson-Bolzmann equation.)LN
EL
SL
(     Journal of Computational Chemistry, 12 \(1990\) 435-445)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, SelectAtom, DrawPrec, Group, PathNames,)LN
EL
SL
(     AddSurface, ReadPot, PaintSurface)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960621)LN
EL

