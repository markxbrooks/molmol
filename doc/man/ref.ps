()LN
EL
SL
(NAME)LN
EL
SL
(     SetUndo - set the number of possible undos)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     SetUndo expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the number of possible undos. Each level can)LN
EL
SL
(     use a significant amount of memory, so setting the)LN
EL
SL
(     number too high is not recommended if the available)LN
EL
SL
(     memory is tight. There is also a certain overhead)LN
EL
SL
(     for each command as soon as the level is greater)LN
EL
SL
(     than zero, especially if many structures are loaded.)LN
EL
SL
(     So if the program seems to get too slow, try setting)LN
EL
SL
(     the value to zero.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     SetUndo 3)LN
EL
SL
()LN
