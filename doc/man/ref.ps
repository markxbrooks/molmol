SL
()LN
EL
SL
(           $Zoom = 1.5)LN
EL
SL
(           $rotY = 90 "Rotate Y")LN
EL
SL
()LN
EL
SL
(           ZoomRel $Zoom)LN
EL
SL
(           RotateY $rotY)LN
EL
SL
(         end)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
