SL
()LN
EL
SL
(NAME)LN
EL
SL
(     PaintRibbon - set coloring style of ribbons)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PaintRibbon \( one_color | two_color |)LN
EL
SL
(         atom | atom_smooth | as_is \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the coloring style of all selected ribbons.)LN
EL
SL
(     With the value one_color, the ribbon will be drawn)LN
EL
SL
(     entirely in the color set with ColorPrim. With)LN
EL
SL
(     two_color, one side will be drawn with the color)LN
EL
SL
(     set by TintPrim. With the value atom, the color for)LN
EL
SL
(     each section is taken from the color of the atom)LN
EL
SL
(     that was used to define the ribbon, normally the)LN
EL
SL
(     CA atom for proteins. atom_smooth will do the same,)LN
EL
SL
(     only that the color change between the sections is)LN
EL
SL
(     smooth. The value as_is will leave the value)LN
EL
SL
(     unchanged.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PaintRibbon one_color)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddRibbon, SelectPrim, ColorPrim, TintPrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     951210)LN
EL

