SL
(     FigAngles - show angle distribution bars)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     FigAngles nameList expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Create a figure showing the angle distributions as)LN
EL
SL
(     points inside bars. Only selected angles are shown.)LN
EL
SL
(     The first argument is a space separated list of all)LN
EL
SL
(     angle names shown in the plot. If there is a gap)LN
EL
SL
(     greater than the value given as second argument, the)LN
EL
SL
(     bar indicating the angle range will be split.)LN
EL
SL
()LN
EL
SL
(     The user can select angles by clicking on symbols)LN
EL
SL
(     in the plot.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     FigAngles 'PHI PSI' 45)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAngle, Group, FigOff, FigCircles)LN
EL
SL
()LN
