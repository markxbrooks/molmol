()LN
EL
SL
(NAME)LN
EL
SL
(     LengthBond - set length of bonds for display)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     LengthBond expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the displayed length of all selected bonds. The)LN
EL
SL
(     first argument gives the start parameter, the second)LN
EL
SL
(     argument the end parameter, the parameter range 0 to 1)LN
EL
SL
(     refers to the original size of the bond.)LN
EL
SL
()LN
EL
SL
(     Note that this command does not actually modify)LN
EL
SL
(     coordinates that would e. g. be written to a)LN
EL
SL
(     coordinate file, it only changes the way bonds are)LN
EL
SL
(     displayed. The command is especially useful when)LN
EL
SL
(     drawing side chains in ribbon diagrams, where the)LN
EL
SL
(     bonds from CA to CB would otherwise not match with)LN
EL
SL
(     beta strands.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     LengthBond -0.5 1)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectBond, AddRibbon)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970219)LN
EL

