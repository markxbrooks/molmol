SL
()LN
EL
SL
(NAME)LN
EL
SL
(     TextureAtom - set texture of atoms)LN
EL
SL
(     TextureBond - set texture of bonds)LN
EL
SL
(     TextureDist - set texture of distances)LN
EL
SL
(     TexturePrim - set texture of primitives)LN
EL
SL
(     TextureInit - set initial texture)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     TextureAtom string expr expr expr)LN
EL
SL
(     TextureBond string expr expr expr)LN
EL
SL
(     TextureDist string expr expr expr)LN
EL
SL
(     TexturePrim string expr expr expr)LN
EL
SL
(     TextureInit string expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     The first four commands set the texture mapping)LN
EL
SL
(     parameters of all selected atoms, bonds, distances)LN
EL
SL
(     or primitives. TextureInit sets the initial)LN
EL
SL
(     texture mapping parameters used for new objects.)LN
EL
SL
()LN
EL
SL
(     The first parameter gives the name of a texture,)LN
EL
SL
(     the second paramter its scaling factor.)LN
EL
SL
()LN
EL
SL
(     The third parameter determines the amount of)LN
EL
SL
(     bumpiness of the surface. 0.0 results in a smooth)LN
EL
SL
(     surface, 1.0 in a very bumpy surface. The fourth)LN
EL
SL
(     paramter is a scaling factor for the bump pattern,)LN
EL
SL
(     a larger scaling factor will result in wider bumps.)LN
EL
SL
()LN
EL
SL
(     Texture mapping is not supported on screen, these)LN
EL
SL
(     parameters are used for preparing files for)LN
EL
SL
(     ray-tracing \(PlotPOV\).)LN
EL
SL
()LN
EL
SL
(     The texture name must appear in the texture definition)LN
EL
SL
(     file of POV-Ray \(textures.inc\). If a texture is)LN
EL
SL
(     selected, the attributes of this texture will override)LN
EL
SL
(     the colors and material properties selected otherwise.)LN
EL
SL
(     If the name has the extension ".gif", it is assumed to)LN
EL
SL
(     be the name of a GIF file which is used as image map.)LN
EL
SL
()LN
EL
SL
(     Giving a value of 'as is' for the texture name or)LN
EL
SL
(     less than 0.0 for any numerical argument will not)LN
EL
SL
(     change it, this is useful for changing only part of)LN
EL
SL
(     the parameters.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     TextureAtom 'Blood_Marble' 0.5 0.0 1.0)LN
EL
SL
(     TextureBond '' 1.0 0.5 1.0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     Select*, Color*, Material*, PlotPov)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     991016)LN
EL

grestore

