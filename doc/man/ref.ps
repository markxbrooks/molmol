(NAME)LN
EL
SL
(     MoveDrawobj - move draw object)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     MoveDrawobj expr expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Move all selected draw objects \(like lines or)LN
EL
SL
(     rectangles\) by the given amount. The first argument)LN
EL
SL
(     gives the index of the control point \(starting at 0\))LN
EL
SL
(     to be moved, the rest of the arguments give the)LN
EL
SL
(     amount of movement in each direction.)LN
EL
SL
()LN
EL
SL
(     Moving the control points of drawing objects is)LN
EL
SL
(     normally done interactively by using the middle)LN
EL
SL
(     mouse button.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     MoveDrawObj 0 0.3 0.1 0.2)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddDrawobj, SelectPrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950618)LN
EL

