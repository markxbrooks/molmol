EL
SL
(NAME)LN
EL
SL
(     PlotTiff - make a TIFF plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotTiff fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Save the current screen contents as TIFF File. The)LN
EL
SL
(     horizontal resolution can be set with the PlotPar)LN
EL
SL
(     command, the vertical resolution is calculated to)LN
EL
SL
(     maintain the aspect ratio of the screen.)LN
EL
SL
()LN
EL
SL
(     This command is not supported on all machines and)LN
EL
SL
(     with all graphics systems. It will give an appropriate)LN
EL
SL
(     error message if it is not supported.)LN
EL
SL
()LN
EL
SL
(     The freely available TIFF library written by)LN
EL
SL
(     Sam Leffler, Copyright \(c\) 1988-1995 Sam Leffler and)LN
EL
SL
(     Silicon Graphics, is used for writing the TIFF file.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotTiff /home/joe/MyPlot.tif)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPar, PlotJpeg, PlotPng,)LN
EL
SL
(     PlotFm3, PlotFm4, PlotPs)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960625)LN
EL

