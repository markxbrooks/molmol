SL
()LN
EL
SL
(NAME)LN
EL
SL
(     MeanMol - create mean molecule)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     MeanMol name)LN
EL
SL
(         \( avg_bfactor | max_disp | rms_disp | x_ray \))LN
EL
SL
(         \( mean_only | set_all \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Create a new molecule with the given name. The new)LN
EL
SL
(     molecule will be the mean structure of all selected)LN
EL
SL
(     molecules. At least one molecule must be selected,)LN
EL
SL
(     and all selected molecules must have the same)LN
EL
SL
(     structure.)LN
EL
SL
()LN
EL
SL
(     The second argument determines how the B-factors)LN
EL
SL
(     of the new molecule are set:)LN
EL
SL
()LN
EL
SL
(         avg_bfactor: average value of all B-factors)LN
EL
SL
()LN
EL
SL
(         max_disp: maximal displacement from mean)LN
EL
SL
(             structure)LN
EL
SL
()LN
EL
SL
(         rms_disp: root mean square of all displacements)LN
EL
SL
()LN
EL
SL
(         x_ray: values corresponding to B-factors used)LN
EL
SL
(             for X-ray structures \(mean square displacement)LN
EL
SL
(             multiplied by 8/3 * pi * pi\))LN
EL
SL
()LN
EL
SL
(     If the third argument is mean_only, this B-factors)LN
EL
SL
(     are only set in the new mean structure, if it is)LN
EL
SL
(     set_all, the B-factors of all selected structures are)LN
EL
SL
(     set to this value.)LN
EL
SL
()LN
EL
SL
(     The newly created molecule will have the property)LN
EL
SL
(     "mean".)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     MeanMol "mean" rms_disp mean_only)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, RemoveMol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960314)LN
EL

