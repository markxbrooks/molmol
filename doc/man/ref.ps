SL
()LN
EL
SL
(NAME)LN
EL
SL
(     TypeRibbon - set type of ribbons)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     TypeRibbon \( interpol | smooth | as_is \))LN
EL
SL
(         \( free | cylinder | spacing | neighbour | as_is \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the type of all selected ribbons. The first)LN
EL
SL
(     argument determines whether the ribbon goes through)LN
EL
SL
(     the atoms used for AddRibbon, or whether it is)LN
EL
SL
(     smoothed. The second argument determines how the)LN
EL
SL
(     ribbon is oriented.)LN
EL
SL
()LN
EL
SL
(     Typically interpol/cylinder or interpol/spacing is)LN
EL
SL
(     used for helices, smooth/neighbour for sheets and)LN
EL
SL
(     smooth/free for turns and random coil.)LN
EL
SL
()LN
EL
SL
(     'cylinder' does a least square fit of a cylinder)LN
EL
SL
(     surface to the atoms, 'spacing' fits a cylinder so)LN
EL
SL
(     that the spacing of atoms along the axis is as)LN
EL
SL
(     regular as possible. The results are very similar)LN
EL
SL
(     in most cases, but 'spacing' often looks better)LN
EL
SL
(     for very short helices or DNA.)LN
EL
SL
()LN
EL
SL
(     The information about which residue is the neighbour)LN
EL
SL
(     of which other residue is read from the secondary)LN
EL
SL
(     structure information in PDB files or calculated by)LN
EL
SL
(     the CalcSecondary command. It can also be set with)LN
EL
SL
(     the SetNeigh command.)LN
EL
SL
()LN
EL
SL
(     For both arguments, the value 'as_is' will leave the)LN
EL
SL
(     value unchanged, this is useful when one wants to)LN
EL
SL
(     change one of the values for multiple ribbons at once.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     TypeRibbon smooth neighbour)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadPdb, CalcSecondary, SetNeigh,)LN
EL
SL
(     AddRibbon, SelectPrim, LengthPrim,)LN
EL
SL
(     StyleRibbon, SizeRibbon, PaintRibbon)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950307)LN
EL

