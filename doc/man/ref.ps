()LN
EL
SL
(NAME)LN
EL
SL
(     ReadAng - read DIANA dihedral angle file)LN
EL
SL
(     ReadListAng - read list of DIANA dihedral angle files)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadAng fileName)LN
EL
SL
(     ReadListAng fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read a dihedral angle file like it is generated by)LN
EL
SL
(     DIANA or DYANA. The file can contain more than one)LN
EL
SL
(     structure. If only one structure is stored in the)LN
EL
SL
(     file, the file name is taken as name of the molecule.)LN
EL
SL
(     If there are multiple structures, numbers are appended)LN
EL
SL
(     to the file name for generating the molecule names.)LN
EL
SL
()LN
EL
SL
(     ReadListAng expects a file with one file name per line)LN
EL
SL
(     \(empty lines allowed\), and reads all these files.)LN
EL
SL
()LN
EL
SL
(     All residues must appear in the residue library:)LN
EL
SL
()LN
EL
SL
(         $MOLMOLHOME/setup/amber94.lib)LN
EL
SL
()LN
EL
SL
(     Angle files can only represent structures if the only)LN
EL
SL
(     conformational changes from the standard geometry in)LN
EL
SL
(     the residue library are rotations about dihedral)LN
EL
SL
(     angles. This is the case for structures calculated in)LN
EL
SL
(     dihedral angle space \(DIANA\), but not e. g. for energy)LN
EL
SL
(     minimized structures. It is also essential to use the)LN
EL
SL
(     same library that was used for the calculations,)LN
EL
SL
(     otherwise structures can be distorted due to slight)LN
EL
SL
(     differences in the standard geometry in the different)LN
EL
SL
(     libraries. It is generally safer to use coordinate)LN
EL
SL
(     files to avoid these problems.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadAng /home/joe/struct/my_prot.ang)LN
EL
SL
(     ReadListAng /home/joe/struct/my_prot.nam)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PathNames, ReadDg, ReadPdb, WriteAng)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950704)LN
EL

