()LN
EL
SL
(NAME)LN
EL
SL
(     ReadSybyl - read SYBYL Mol2 file)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadSybyl fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     ReadSybyl reads a file in the Mol2 file format used by)LN
EL
SL
(     the program SYBYL by Tripos. The entries MOLECULE,)LN
EL
SL
(     ATOM, BOND, SUBSTRUCTURE and SET \(STATIC\) are)LN
EL
SL
(     interpreted, everything else is ignored. Special)LN
EL
SL
(     characters \(like $\) in set \(i. e. property\) names are)LN
EL
SL
(     not allowed by MOLMOL, they are replaced with)LN
EL
SL
(     underscores while reading.)LN
EL
SL
()LN
EL
SL
(     When necessary, numbers are added to residue and atom)LN
EL
SL
(     names to make them unique.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadSybyl /home/sybyl/demo/vit_c.mol2)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PathNames, ReadDg, ReadAng, ReadPdb)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960312)LN
EL

