()LN
EL
SL
(NAME)LN
EL
SL
(     RotateX - rotate molecule around X axis)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     RotateX expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Rotate all movable \(set with DialMol\) molecules by)LN
EL
SL
(     the given angle around the X axis. The X axis runs)LN
EL
SL
(     from left to right of the screen. Rotation is)LN
EL
SL
(     normally done interactively by pressing the left)LN
EL
SL
(     mouse button. This command is useful for being used)LN
EL
SL
(     in macros or for setting up the slider box.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     RotateX 90)LN
EL
SL
