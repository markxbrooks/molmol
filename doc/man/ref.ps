SL
()LN
EL
SL
(NAME)LN
EL
SL
(     SelectMol   - select molecules)LN
EL
SL
(     SelectRes   - select residues)LN
EL
SL
(     SelectAtom  - select atoms)LN
EL
SL
(     SelectBond  - select bonds)LN
EL
SL
(     SelectAngle - select angles)LN
EL
SL
(     SelectDist  - select distances)LN
EL
SL
(     SelectPrim  - select primitives)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     SelectMol expr)LN
EL
SL
(     SelectRes expr)LN
EL
SL
(     SelectAtom expr)LN
EL
SL
(     SelectBond expr)LN
EL
SL
(     SelectAngle expr)LN
EL
SL
(     SelectDist expr)LN
EL
SL
(     SelectPrim expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Select molecules, residues, atoms, bonds, angles,)LN
EL
SL
(     distances or primitives that satisfy a conditions)LN
EL
SL
(     specified by an expression. The expression must)LN
EL
SL
(     give a result of type boolean \(truth value\).)LN
EL
SL
()LN
EL
SL
(     There are two special values not covered by the)LN
EL
SL
(     expression syntax below. If an empty string is given)LN
EL
SL
(     as expression, everything is selected. If the value)LN
EL
SL
(     "0" is given, nothing is selected \(i. e. everything)LN
EL
SL
(     deselected\).)LN
EL
SL
()LN
EL
SL
(     The following is a formal sytax description of)LN
EL
SL
(     expressions in EBNF notation. Typical examples are)LN
EL
SL
(     shown in the next section.)LN
EL
SL
()LN
EL
SL
(       expr       = andExpr { "|" andExpr } .)LN
EL
SL
(       andExpr    = relExpr { "&" relExpr } .)LN
EL
SL
(       relExpr    = simpleExpr [ relOp setExpr ] .)LN
EL
SL
(       relOp      = "=" | "!=" | "<=" |)LN
EL
SL
(                    "<" | ">=" | ">" .)LN
EL
SL
(       setExpr    = rangeExpr { "," rangeExpr } .)LN
EL
SL
(       rangeExpr  = simpeExpr [ ".." simpleExpr ] .)LN
EL
SL
(       simpleExpr = term { addOp term } .)LN
EL
SL
(       addOp      = "+" | "-" .)LN
EL
SL
(       term       = factor { mulOp factor } .)LN
EL
SL
(       mulOp      = "*" | "/" | "%" .)LN
EL
SL
(       factor     = [ "-" | "sqrt" | "log" | "!" ] primary .)LN
EL
SL
(       primary    = constant | designator | "\(" expr "\)" .)LN
EL
SL
(       constant   = string | int | float .)LN
EL
SL
(       designator = [ qual "." ] field [ "[" int "]" ] .)LN
EL
SL
(       qual       = "mol" | "mol1" | "mol2" |)LN
EL
SL
(                    "res" | "res1" | "res2" | "atom" |)LN
EL
SL
(                    "atom1" | "atom2" | "atom3" | "atom4" |)LN
EL
SL
(                    "bond" | "angle" | "dist" | "prim" .)LN
EL
SL
(       field      = "num" | "number" | "name" | "attr" |)LN
EL
SL
(                    "shift" | "bfactor" | "vdw" | "d" |)LN
EL
SL
(                    "charge" | "heavycharge" |)LN
EL
grestore

