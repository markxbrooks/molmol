SL
()LN
EL
SL
(NAME)LN
EL
SL
(     ZoomAbs - zoom absolute)LN
EL
SL
(     ZoomRel - zoom relative)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ZoomAbs expr)LN
EL
SL
(     ZoomRel expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Enlarge/reduce the size of the display. ZoomRel)LN
EL
SL
(     changes the size by a given factor, relative to the)LN
EL
SL
(     current size.  Factors greater than 1 make the)LN
EL
SL
(     display larger, factors less than 1 make it smaller.)LN
EL
SL
(     ZoomAbs sets the zoom factor to an absolute value.)LN
EL
SL
()LN
EL
SL
(     ZoomAbs, in conjunction with PlotPar, can be used to)LN
EL
SL
(     produce different plots with the same scale. If the)LN
EL
SL
(     zoom factor and the plot size are set to the same)LN
EL
SL
(     values, the scales will be identical.)LN
EL
SL
()LN
EL
SL
(     Zooming is normally done interactively by pressing)LN
EL
SL
(     the left and the middle mouse button.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     ZoomAbs 0.2)LN
EL
SL
(     ZoomRel 1.4)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPar)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950124)LN
EL

