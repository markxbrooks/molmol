()LN
EL
SL
(Definiton of Actions)LN
EL
SL
(--------------------)LN
EL
SL
()LN
EL
SL
(click:     press one \(or multiple\) mouse button\(s\) and)LN
EL
SL
(           release them without moving the mouse)LN
EL
SL
()LN
EL
SL
(click+mod: hold down a modifier key \(Shift or Ctrl\) and)LN
EL
SL
(           click.)LN
EL
SL
()LN
EL
SL
(drag:      press one \(or multiple\) mouse button\(s\), move)LN
EL
SL
(           the mouse, and release the button\(s\))LN
EL
SL
()LN
EL
SL
()LN
EL
SL
(Table of Actions)LN
EL
SL
(----------------)LN
EL
SL
()LN
EL
SL
(                   | click  | click+mod   | drag)LN
EL
SL
(------------------------------------------------------------)LN
EL
SL
(left               | select | select add. | rotate)LN
EL
SL
(------------------------------------------------------------)LN
EL
SL
(middle \(in text\)   |  toggle text select  | move/resize text)LN
EL
SL
(------------------------------------------------------------)LN
EL
SL
(middle \(elsewhere\) | select | select add. | move molecules)LN
EL
SL
(------------------------------------------------------------)LN
EL
SL
(left+middle        |        |             | zoom)LN
EL
SL
(------------------------------------------------------------)LN
EL
SL
(right              | popup  |             |)LN
EL
SL
(------------------------------------------------------------)LN
EL

