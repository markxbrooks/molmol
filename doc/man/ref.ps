()LN
EL
SL
(NAME)LN
EL
SL
(     AddCylinder - add cylinder for schematic drawing)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddCylinder \( least_square | spacing \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add a cylinder that approximates the selected atoms.)LN
EL
SL
(     The argument selects between two fit criteria.)LN
EL
SL
(     'least_square' does a least square fit of the cylinder)LN
EL
SL
(     surface to the atoms, 'spacing' takes the axis)LN
EL
SL
(     direction that gives the most regular spacing of)LN
EL
SL
(     atoms. The results are normally very similar, but)LN
EL
SL
(     'spacing' works better than 'least_square' if very)LN
EL
SL
(     few atoms are given.)LN
EL
SL
()LN
EL
SL
(     A cylinder is added for each molecule that has)LN
EL
SL
(     selected atoms. A minimum number of atoms \(5 for)LN
EL
SL
(     least_square, 4 for spacing\) must be selected,)LN
EL
SL
(     otherwise the cylinder cannot be determined and an)LN
EL
SL
(     error message is issued.)LN
EL
SL
()LN
EL
SL
(     Cylinders can be used for showing alpha helices in)LN
EL
SL
(     schematic drawings. For good results, it is)LN
EL
SL
(     recommended to either select the CA or all backbone)LN
EL
SL
(     atoms within a helix region.)LN
EL
SL
()LN
EL
SL
(     The created primitives have the property "cylinder".)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddCylinder spacing)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, StyleCylinder, ColorPrim, LengthPrim,)LN
EL
SL
(     RemovePrim, AddRibbon, AddSolid, AddDipole)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970930)LN
EL

grestore

