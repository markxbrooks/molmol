()LN
EL
SL
(NAME)LN
EL
SL
(     ReadPdb - read PDB file)LN
EL
SL
(     ReadListPdb - read list of PDB files)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadPdb fileName)LN
EL
SL
(     ReadListPdb fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read a PDB file. The file can contain more than one)LN
EL
SL
(     structure. If only one structure is stored in the file,)LN
EL
SL
(     the file name is taken as name of the molecule. If)LN
EL
SL
(     there are multiple structures, numbers are appended)LN
EL
SL
(     to the file name for generating the molecule names.)LN
EL
SL
()LN
EL
SL
(     ReadListPdb expects a file with one file name per line)LN
EL
SL
(     \(empty lines allowed\), and reads all these files.)LN
EL
SL
()LN
EL
SL
(     If residues appear in the residue library)LN
EL
SL
(     \($MOLMOLHOME/setup/amber94.lib by default, can be)LN
EL
SL
(     changed with the PathNames command\), the covalent)LN
EL
SL
(     structure is taken from there. If a residue is not)LN
EL
SL
(     present in the library, just the atom coordianates are)LN
EL
SL
(     read from the PDB file. The user can add bonds with)LN
EL
SL
(     the command CalcBond later.)LN
EL
SL
()LN
EL
SL
(     Because the PDB naming conventions do not fully)LN
EL
SL
(     correspond with the names in the residue library of)LN
EL
SL
(     MOLMOL, a translation table for atom names is used.)LN
EL
SL
(     This is $MOLMOLHOME/setup/PdbAtoms by default, and)LN
EL
SL
(     can be changed with the PathNames command.)LN
EL
SL
()LN
EL
SL
(     The command also reads secondary structure information)LN
EL
SL
(     \(HELIX and SHEET records\) and sets the corresponding)LN
EL
SL
(     properties on the residues. They are used by the)LN
EL
SL
(     AddRibbon command to create schematic drawings.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadPdb /home/joe/struct/my_prot.pdb)LN
EL
SL
(     ReadListPdb /home/joe/struct/my_prot.nam)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PathNames, ReadAng, ReadDg, WritePdb,)LN
EL
SL
(     CalcBond, AddRibbon)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950704)LN
EL

