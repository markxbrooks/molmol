(NAME)LN
EL
SL
(     ReadDump - read dump file)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadDump fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read a dump file. A dump file is a binary file that)LN
EL
SL
(     contains the complete program state. A dump file)LN
EL
SL
(     with the name molmol/dump in the users home)LN
EL
SL
(     directory is created whenever the user leaves the)LN
EL
SL
(     program. A dump file with an arbitrary name can be)LN
EL
SL
(     created anytime by using the command WriteDump.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadDump /home/joe/struct/my_prot.mml)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     WriteDump)LN
EL
SL
()LN
EL
SL
