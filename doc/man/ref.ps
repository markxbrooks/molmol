()LN
EL
SL
(NAME)LN
EL
SL
(     ReadDg - read DG file)LN
EL
SL
(     ReadListDg - read list of DG files)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadDg fileName)LN
EL
SL
(     ReadListDg fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     ReadDg reads a file in DG format. Since no clear)LN
EL
SL
(     separation of molecules is supported by the DG format,)LN
EL
SL
(     it is assumed that a new molecule starts whenever the)LN
EL
SL
(     residue number decreases.)LN
EL
SL
()LN
EL
SL
(     ReadListDg expects a file with one file name per line)LN
EL
SL
(     \(empty lines allowed\), and reads all these files.)LN
EL
SL
()LN
EL
SL
(     If residues appear in the residue library)LN
EL
SL
(     \($MOLMOLHOME/setup/amber94.lib by default\), the)LN
EL
SL
(     covalent structure is taken from there. The optional)LN
EL
SL
(     connection information of the DG format is also read,)LN
EL
SL
(     bonds not already known from the residue library are)LN
EL
SL
(     inserted. If there is no connection information at)LN
EL
SL
(     all, the user can add bonds with the command CalcBond)LN
EL
SL
(     later.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadDg /home/joe/struct/my_prot.cor)LN
EL
SL
(     ReadListDg /home/joe/struct/my_prot.nam)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PathNames, ReadAng, ReadPdb, WriteDg, CalcBond)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     951116)LN
EL

