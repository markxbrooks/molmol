()LN
EL
SL
(NAME)LN
EL
SL
(     Light - setup of light source)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     Light \( off | point | infinite \) expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     The first argument selects between no light source,)LN
EL
SL
(     a point light source or a light source at infinity.)LN
EL
SL
(     The coordinates are used as position if a point light)LN
EL
SL
(     source was chosen as point, or only as direction for)LN
EL
SL
(     an infinite light source. Point light sources might)LN
EL
SL
(     not be supported on all hardware, or they may be)LN
EL
SL
(     slower than infinite light sources.)LN
EL
SL
()LN
EL
SL
(     Coordinates are so that the origin is at the center)LN
EL
SL
(     of the screen, the x-axis points to the right, the)LN
EL
SL
(     y-axis to the top, and the z-axis out of the screen.)LN
EL
SL
(     The viewpoint \(eye, camera\) is at \(0, 0, 10\).)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Light point 0 5 5)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950824)LN
EL

