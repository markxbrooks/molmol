SL
()LN
EL
SL
(NAME)LN
EL
SL
(     AddSurface - add surface)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddSurface expr \( vdw | solvent | contact \) expr)LN
EL
SL
(         \( dots | shaded \) \( 0 | 1 \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add a surface for the selected atoms. The precision)LN
EL
SL
(     \(density of the dots\) depends on DrawPrec.)LN
EL
SL
()LN
EL
SL
(     The first argument is the radius of the atoms, you)LN
EL
SL
(     will normally not change the default value 'vdw'.)LN
EL
SL
()LN
EL
SL
(     The second argument gives the type of surface:)LN
EL
SL
()LN
EL
SL
(         vdw: van der Waals surface)LN
EL
SL
()LN
EL
SL
(         solvent: surface given by the center)LN
EL
SL
(             of spheres \(solvent\) touching the atoms)LN
EL
SL
()LN
EL
SL
(         contact: contact surface \(Richards\))LN
EL
SL
()LN
EL
SL
(     The third argument gives the solvent radius for)LN
EL
SL
(     solvent and contact surfaces.)LN
EL
SL
()LN
EL
SL
(     The fourth argument gives the type of surface,)LN
EL
SL
(     dots or a solid, shaded surface can be selected.)LN
EL
SL
()LN
EL
SL
(     The final option selects whether a report with the)LN
EL
SL
(     approximate areas and volumes of all surface parts)LN
EL
SL
(     is desired. The volumes are mainly interesting for)LN
EL
SL
(     cavities. Note that the numbers are not highly)LN
EL
SL
(     precise.)LN
EL
SL
()LN
EL
SL
(     Depending on the precision, shaded surfaces can use)LN
EL
SL
(     a lot of memory. If the machine runs out of memory,)LN
EL
SL
(     the program may crash occasionally.)LN
EL
SL
()LN
EL
SL
(     This command supports groups for shaded surfaces,)LN
EL
SL
(     the resulting surface will belong to the first)LN
EL
SL
(     group member.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddSurface vdw contact 1.4 dots 0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, RadiusAtom, DrawPrec, Group,)LN
EL
SL
(     ColorPrim, RemovePrim, CalcSurface)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970723)LN
EL

grestore

