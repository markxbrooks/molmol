EL
SL
(     ChangeRes - change residue type)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ChangeRes \( angles | atoms \) name)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Exchange all selected residues with a different)LN
EL
SL
(     residue type given as second argument. If the first)LN
EL
SL
(     argument is 'angles', the old conformation is)LN
EL
SL
(     maintained by copying the values of the common)LN
EL
SL
(     dihedral angles from the old residue to the new)LN
EL
SL
(     residue. If it is 'atoms', the old conformation is)LN
EL
SL
(     maintained by copying the coordinates of the common)LN
EL
SL
(     atoms from the old residue to the new residue.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ChangeRes angles "ARG")LN
EL
SL
()LN
EL
SL
