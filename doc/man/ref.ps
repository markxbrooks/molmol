()LN
EL
SL
(NAME)LN
EL
SL
(     PlotJpeg - make a JPEG plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotJpeg fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Save the current screen contents as JPEG File. The)LN
EL
SL
(     horizontal resolution can be set with the PlotPar)LN
EL
SL
(     command, the vertical resolution is calculated to)LN
EL
SL
(     maintain the aspect ratio of the screen.)LN
EL
SL
()LN
EL
SL
(     Note that that JPEG uses a lossy compression scheme,)LN
EL
SL
(     the quality factor can be adjusted with the PlotPar)LN
EL
SL
(     command.)LN
EL
SL
()LN
EL
SL
(     This command is not supported on all machines and)LN
EL
SL
(     with all graphics systems. It will give an appropriate)LN
EL
SL
(     error message if it is not supported.)LN
EL
SL
()LN
EL
SL
(     The freely available JPEG library written by the)LN
EL
SL
(     Independent JPEG Group is used for writing the JPEG)LN
EL
SL
(     file.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotJpeg /home/joe/MyPlot.jpg)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotPar, PlotTiff, PlotPng,)LN
EL
SL
(     PlotFm3, PlotFm4, PlotPs)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960625)LN
EL

