EL
SL
(NAME)LN
EL
SL
(     ShadeAtom - set shading of atoms)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ShadeAtom \( none | flat | gouraud | phong |)LN
EL
SL
(         dots | lines \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the shading method for atoms if they are)LN
EL
SL
(     displayed as spheres.)LN
EL
SL
()LN
EL
SL
(         none:    no shading)LN
EL
SL
(         flat:    polygons shaded in uniform color)LN
EL
SL
(         gouraud: color interpolated between vertices)LN
EL
SL
(         phong:   normals interpolated, highest quality)LN
EL
SL
(         dots:    draw surface using dots)LN
EL
SL
(         lines:   draw surface using lines)LN
EL
SL
()LN
EL
SL
(     Not all graphics devices support all shading methods.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ShadeAtom phong)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, StyleAtom, ColorAtom)LN
EL
SL
()LN
EL
