()LN
EL
SL
(NAME)LN
EL
SL
(     DialMol - switch molecule dialog on and off)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     DialMol \( off | on \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Switch molecule dialog on and off. The molecule dialog)LN
EL
SL
(     can be used to select molecules and for toggling their)LN
EL
SL
(     displayed and movable states. It is a convenient)LN
EL
SL
(     interface to the commands SelectMol and DefPropMol.)LN
EL
SL
()LN
EL
SL
(     The radio buttons at the top of the dialog allow the)LN
EL
SL
(     selection of the property that is displayed/modified.)LN
EL
SL
()LN
EL
SL
(     The list contains all currently loaded molecules,)LN
EL
SL
(     where the ones with the corresponding property are)LN
EL
SL
(     highlighted. The property can be modified by)LN
EL
SL
(     selecting and unselecting entries in the list. Note)LN
EL
SL
(     that you can make multiple/extended selections by)LN
EL
SL
(     holding down the Shift or Ctrl key while clicking on)LN
EL
SL
(     entries in the list.)LN
EL
SL
()LN
EL
SL
(     The OK button closes the dialog, the Help button shows)LN
EL
SL
(     this help page.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     DialMol on)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, DefPropMol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980409)LN
EL

