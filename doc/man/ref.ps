(NAME)LN
EL
SL
(     ReadLib - read and error check residue library)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadLib)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read the residue library. This command is not normally)LN
EL
SL
(     used, the residue library is read automatically when)LN
EL
SL
(     needed. This command gives diagnostic output, however,)LN
EL
SL
(     where normally errors in the residue library are not)LN
EL
SL
(     reported. So this command is helpful for checking the)LN
EL
SL
(     library after modifications, or whenever problems are)LN
EL
SL
(     suspected.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadLib)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PathNames, InitAll, WriteLib)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961206)LN
EL

