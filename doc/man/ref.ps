SL
()LN
EL
SL
(NAME)LN
EL
SL
(     CheckUpl - check upper limits)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     CheckUpl expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Check all selected upper limits for violation in)LN
EL
SL
(     any of the selected molecules. The command will)LN
EL
SL
(     generate a report with all violations greater than)LN
EL
SL
(     the cutoff given as first argument if it occurs in)LN
EL
SL
(     at least the number of structures given as second)LN
EL
SL
(     argument.)LN
EL
SL
()LN
EL
SL
(     The upper limits do not have to be read/added for)LN
EL
SL
(     all structures, it is enough if they are defined)LN
EL
SL
(     for one structure. If different upper limits are)LN
EL
SL
(     present in different structures, the smallest is)LN
EL
SL
(     considered for the report.)LN
EL
SL
()LN
EL
SL
(     In the report produced by this command, a table of)LN
EL
SL
(     violations will be created for each set of molecules)LN
EL
SL
(     with the same structure. A '+' sign indicates that)LN
EL
SL
(     the violation is present in the molecule corresponding)LN
EL
SL
(     to the column, a '*' marks the largest of these)LN
EL
SL
(     violations. The '+' sign is replaced by a '5' for)LN
EL
SL
(     molecules 5, 15, 25, ... and by a '0' for molecules)LN
EL
SL
(     10, 20, 30, ...)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CheckUpl 0.3 1)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadUpl, AddUpl, Group, RemoveDist, SelectDist,)LN
EL
SL
(     CheckLol, CheckAco)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     981101)LN
EL

grestore

gsave
/Times-Bold findfont 13837 scalefont setfont

