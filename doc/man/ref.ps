()LN
EL
SL
(NAME)LN
EL
SL
(     ReadSeq - read sequence)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadSeq fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read a sequence. The file must contain the name of)LN
EL
SL
(     a residue on each line. All residues must appear in)LN
EL
SL
(     the residue library:)LN
EL
SL
()LN
EL
SL
(         $MOLMOLHOME/setup/amber94.lib)LN
EL
SL
()LN
EL
SL
(     The molecule will be in an extended conformation,)LN
EL
SL
(     with the standard geometry used for all residues.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadSeq /home/joe/struct/my_prot.seq)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PathNames, ReadAng, ReadDg, ReadPdb, WriteSeq)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950704)LN
EL

