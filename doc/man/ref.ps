()LN
EL
SL
(NAME)LN
EL
SL
(     ReplaceDg - replace with DG file)LN
EL
SL
(     ReplaceListDg - replace with list of DG files)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReplaceDg fileName)LN
EL
SL
(     ReplaceListDg fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     ReplaceDg reads coordinates from a file in DG format,)LN
EL
SL
(     replacing the coordinates of the currently selected)LN
EL
SL
(     molecule. If no molecule is selected, a new molecule)LN
EL
SL
(     will be created. The structure in the file should be)LN
EL
SL
(     identical to the structure of the selected molecule,)LN
EL
SL
(     otherwise the result will not be very useful.)LN
EL
SL
()LN
EL
SL
(     ReplaceListDg expects a file with one file name per)LN
EL
SL
(     line \(empty lines allowed\), and reads coordinates)LN
EL
SL
(     from all these files, replacing the coordinates of)LN
EL
SL
(     the selected molecules.)LN
EL
SL
()LN
EL
SL
(     See ReadDg for more information about the DG format.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReplaceDg /home/joe/struct/my_prot.cor)LN
EL
SL
(     ReplaceListDg /home/joe/struct/my_prot.nam)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadDg, ReadListDg)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950626)LN
EL

