()LN
EL
SL
(NAME)LN
EL
SL
(     NearPrim - set near clipping plane of primitives)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     NearPrim expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the position of the near clipping plane of all)LN
EL
SL
(     selected primitives. The position is given as distance)LN
EL
SL
(     from the viewing point, the center of the display has)LN
EL
SL
(     distance 10.0 from the viewing point. When a negative)LN
EL
SL
(     value is given, the current value will be unchanged.)LN
EL
SL
(     When 0.0 is given, no separate clipping will be done,)LN
EL
SL
(     the global clipping planes set by ClipPos and ClipSize)LN
EL
SL
(     are then used.)LN
EL
SL
()LN
EL
SL
(     This command is mainly useful for surfaces, by)LN
EL
SL
(     clipping away the front part it is possible to see)LN
EL
SL
(     the inside.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     NearPrim 8.0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectPrim, AddSurface, ClipPos, ClipSize, TrimSurface)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970718)LN
EL

grestore

