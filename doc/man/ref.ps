()LN
EL
SL
(NAME)LN
EL
SL
(     ReadPot - read potentials for surface coloring)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadPot fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read a file with potentials, these are used for)LN
EL
SL
(     coloring surfaces. The file must contain values on a)LN
EL
SL
(     grid, the format is:)LN
EL
SL
()LN
EL
SL
(         x0 xSize xInc)LN
EL
SL
(         y0 ySize yInc)LN
EL
SL
(         z0 zSize zInc)LN
EL
SL
(         val val val ....)LN
EL
SL
()LN
EL
SL
(     where x0, y0, z0 \(float\) are the coordinates of the)LN
EL
SL
(     grid origin, xSize, ySize and zSize \(int\) are the)LN
EL
SL
(     sizes of the grid in each dimension, and xInc, yInc)LN
EL
SL
(     and zInc \(float\) the spacing between two grid points)LN
EL
SL
(     in each dimention. This must be followed by)LN
EL
SL
(     xSize * ySize * zSize values \(float\), where the)LN
EL
SL
(     x-coordinate is the one that is running the fastest.)LN
EL
SL
()LN
EL
SL
(     The potentials will be set for all selected surfaces,)LN
EL
SL
(     but the PaintSurface command has to be given to update)LN
EL
SL
(     the colors.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadPot /home/joe/struct/my_pot.dat)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     CalcPot, AddSurface, SelectPrim, PaintSurface)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960509)LN
EL

