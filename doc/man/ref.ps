()LN
EL
SL
(NAME)LN
EL
SL
(     HelpViewer - set viewer for help files)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     HelpViewer \( UNIX-Netscape | Windows-Explorer |)LN
EL
SL
(         builtin | custom \) string)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Choose a viewer for displaying help files. The first)LN
EL
SL
(     two options set commonly used web browsers on the)LN
EL
SL
(     corresponding platform. With 'builtin', a simple text)LN
EL
SL
(     window is used. When 'custom' is selected, the command)LN
EL
SL
(     given as second argument is used for starting a web)LN
EL
SL
(     browser. For UNIX, this has to be a complete command)LN
EL
SL
(     string, where %f will be replaced by the name of the)LN
EL
SL
(     HTML file. For Windows, it is only the name of a web)LN
EL
SL
(     browser, this must be capable of DDE with the same)LN
EL
SL
(     protocol as Explorer.)LN
EL
SL
()LN
EL
SL
(     Once a help file has been displayed, choosing a)LN
EL
SL
(     different option with this command may only take)LN
EL
SL
(     effect after restarting the program.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     HelpViewer UNIX-Netscape '')LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     HelpCmd)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     971002)LN
EL

