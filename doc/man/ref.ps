SL
(     ViewAngle - set view angle)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ViewAngle expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the view angle. For orthogonal projection, this)LN
EL
SL
(     influences only the size \(zooming factor\) of the)LN
EL
SL
(     display, for perspective projection, a larger view)LN
EL
SL
(     angle leads to a stronger perspective. The value)LN
EL
SL
(     is given in radians.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ViewAngle 0.5)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     Projection, ClipPos, ClipSize)LN
EL
SL
()LN
EL
