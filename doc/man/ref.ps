SL
()LN
EL
SL
(NAME)LN
EL
SL
(     WriteUpl - write file with upper limits)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     WriteUpl fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Write a file with upper distance limits. The format is)LN
EL
SL
(     the same that DIANA/DYANA uses. All selected upper)LN
EL
SL
(     distance limits are written. When a constraint between)LN
EL
SL
(     two atoms appears in more than one molecule, the)LN
EL
SL
(     smallest constraint value is written. All selected)LN
EL
SL
(     distances are also written, for these the actual)LN
EL
SL
(     distance is taken as constraint value.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     WriteUpl /home/joe/struct/my_prot.upl)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, Group, ReadUpl, AddUpl, CheckUpl, WriteLol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980326)LN
EL

grestore

gsave
/Times-Bold findfont 13837 scalefont setfont

