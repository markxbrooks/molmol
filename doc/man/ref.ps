()LN
EL
SL
(NAME)LN
EL
SL
(     AddDipole - add arrow showing dipolar moment)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddDipole)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add an arrow that shows the dipolar moment of the)LN
EL
SL
(     selected atoms. A separate arrow is created for each)LN
EL
SL
(     molecule that has selected atoms.)LN
EL
SL
()LN
EL
SL
(     The arrow is in fact a cylinder, like it is created)LN
EL
SL
(     with AddCylinder, and can be manipulated with the)LN
EL
SL
(     corresponding commands, like StyleCylinder or)LN
EL
SL
(     LengthPrim.)LN
EL
SL
()LN
EL
SL
(     The created primitives have the properties "dipole")LN
EL
SL
(     and "cylinder".)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddDipole)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, StyleCylinder, ColorPrim, LengthPrim,)LN
EL
SL
(     RemovePrim, AddCylinder)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970723)LN
EL

