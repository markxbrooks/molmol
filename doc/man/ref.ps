52500 1034501 moveto
SL
()LN
EL
SL
(NAME)LN
EL
SL
(     MaterialAtom - set material properties of atoms)LN
EL
SL
(     MaterialBond - set material properties of bonds)LN
EL
SL
(     MaterialDist - set material properties of distances)LN
EL
SL
(     MaterialPrim - set material properties of primitives)LN
EL
SL
(     MaterialInit - set initial material properties)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     MaterialAtom expr expr expr expr expr expr expr)LN
EL
SL
(     MaterialBond expr expr expr expr expr expr expr)LN
EL
SL
(     MaterialDist expr expr expr expr expr expr expr)LN
EL
SL
(     MaterialPrim expr expr expr expr expr expr expr)LN
EL
SL
(     MaterialInit expr expr expr expr expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     The first four commands set the material properties)LN
EL
SL
(     of all selected atoms, bonds, distances or primitives.)LN
EL
SL
(     MaterialInit sets the initial material properties used)LN
EL
SL
(     for new objects.)LN
EL
SL
()LN
EL
SL
(     The first three paramters give the coefficients for)LN
EL
SL
(     ambient, diffuse and specular reflection. These values)LN
EL
SL
(     should all be between 0 and 1, for good results the)LN
EL
SL
(     ambient and diffuse terms should sum up to around 1.)LN
EL
SL
()LN
EL
SL
(     The fourth parameter gives the shininess, it only)LN
EL
SL
(     has an effect if the specular coefficient is not zero.)LN
EL
SL
(     Higher values for the shininess result in smaller)LN
EL
SL
(     specular highlights. Values can be from 1.0 \(very)LN
EL
SL
(     dull\) to 200 and more \(highly polished metal\).)LN
EL
SL
()LN
EL
SL
(     The fifth parameter gives the reflection. 1.0 results)LN
EL
SL
(     in a complete reflection of other objects in the scene)LN
EL
SL
(     \(mirror\), 0.0 in no reflection.)LN
EL
SL
()LN
EL
SL
(     The sixth parameter gives the opacity. 1.0 results)LN
EL
SL
(     in a completely opaque material, 0.0 in complete)LN
EL
SL
(     transparency.)LN
EL
SL
()LN
EL
SL
(     The seventh parameter gives the index of refraction,)LN
EL
SL
(     it only has an influence for \(partly\) transparent)LN
EL
SL
(     materials. 1.0 gives no refraction, 1.5 is the value)LN
EL
SL
(     for glass, 2.4 for diamond.)LN
EL
SL
()LN
EL
SL
(     Transparency is not supported on most hardware, and)LN
EL
SL
(     only to a limited amount on machines with high-end)LN
EL
SL
(     graphics. It is mainly useful for preparing files)LN
EL
SL
(     for ray tracing \(PlotPov\). Reflection is not supported)LN
EL
SL
(     on screen, it is only used for ray tracing.)LN
EL
SL
()LN
EL
SL
(     Giving a value less than 0.0 for any value will not)LN
EL
SL
(     change it, this is useful for changing only part of)LN
EL
SL
(     the parameters.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     MaterialAtom 0.3 0.7 0.4 30 0.0 1.0 1.0)LN
EL
grestore

