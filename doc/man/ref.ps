EL
SL
(     Set the display style of all selected bonds. The)LN
EL
SL
(     style 'cylinder' draws the bond as an open cylinder,)LN
EL
SL
(     'neon' draws it as cylinder with round ends, 'cone')LN
EL
SL
(     as cone, taking the radii of the connected atoms.)LN
EL
SL
()LN
EL
SL
(     The styles 'half_line', 'half_cylinder', 'half_neon')LN
EL
SL
(     and 'half_cone' draw the bonds in two parts, taking)LN
EL
SL
(     the colors of the connected atoms.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     StyleBond cylinder)LN
EL
SL
()LN
