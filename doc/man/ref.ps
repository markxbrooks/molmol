()LN
EL
SL
(NAME)LN
EL
SL
(     PlotVrml1 - make a VRML 1.0 plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotVrml1 fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Make a plot of the current screen contents in VRML)LN
EL
SL
(     \(Virtual Reality Modeling Language\) format. VRML is)LN
EL
SL
(     the standard format for transferring and displaying)LN
EL
SL
(     three-dimensional geometry on the World Wide Web.)LN
EL
SL
(     The created files follow version 1.0 of the VRML)LN
EL
SL
(     specifications and can be displayed by any VRML)LN
EL
SL
(     browser supporting VRML 1.0.)LN
EL
SL
()LN
EL
SL
(     Files following the newer VRML 2.0 \(VRML97\))LN
EL
SL
(     standard can be produced with the PlotVrml2)LN
EL
SL
(     command.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotVrml1 /home/joe/MyPlot.wrl)LN
EL
SL
()LN
EL
SL
(WARNING)LN
EL
SL
(     This command was not tested thoroughly. Not all)LN
EL
SL
(     display possibilities of MOLMOL are supported.)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotFm*, PlotPs, PlotPov, PlotVrml2)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     991031)LN
EL

