()LN
EL
SL
(NAME)LN
EL
SL
(     EditText - edit text annotation)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     EditText string)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Change the text of all selected text annotations.)LN
EL
SL
()LN
EL
SL
(     Besides the normal characters, greek letters can be)LN
EL
SL
(     used by entering a \\ \(backslash\)followed by the)LN
EL
SL
(     corresponding latin character \(e. g. \\a for alpha\).)LN
EL
SL
()LN
EL
SL
(     Subscript is started with an _. If more than one)LN
EL
SL
(     character should be displayed in subscript, they)LN
EL
SL
(     have to be enclosed in braces.)LN
EL
SL
()LN
EL
SL
(     Superscript is analogous to subscript, only that)LN
EL
SL
(     the ^ character is used instead of _.)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     EditText "New Text")LN
EL
SL
(     EditText "C_\\a")LN
EL
SL
(     EditText "a^{2 * x}")LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     AddTitle, AddText, ColorPrim, LinePrim, MovePrim,)LN
EL
SL
(     SizeText, RemovePrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     950407)LN
EL

