()LN
EL
SL
(NAME)LN
EL
SL
(     AddCircles - add circles around atoms)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddCircles expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add circles around atoms. This is typically used to)LN
EL
SL
(     indicate mobility or exactness. A circle will be)LN
EL
SL
(     drawn around every selected atom. The selected bonds)LN
EL
SL
(     are used to determine the direction of the circles.)LN
EL
SL
(     The user will normally select atoms of the backbone)LN
EL
SL
(     \(e. g. all CA\) and all bonds of the backbone before)LN
EL
SL
(     executing this command.)LN
EL
SL
()LN
EL
SL
(     The created primitives have the property "circle".)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     AddCircles 0.5)LN
EL
SL
(     AddCircles bfactor)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, SelectBond,)LN
EL
SL
(     ColorPrim, LinePrim, RemovePrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     970723)LN
EL

