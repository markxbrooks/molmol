(NAME)LN
EL
SL
(     WriteDump - write dump file)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     WriteDump fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Write a dump file. A dump file is a binary file that)LN
EL
SL
(     contains the complete program state. A dump file)LN
EL
SL
(     with the name molmol/dump in the users home)LN
EL
SL
(     directory is created whenever the user leaves the)LN
EL
SL
(     program. A dump file with an arbitrary name can be)LN
EL
SL
(     created anytime by using this command.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     WriteDump /home/joe/struct/my_prot.mml)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadDump)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     991017)LN
EL

