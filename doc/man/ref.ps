SL
(     two molecules like this:)LN
EL
SL
()LN
EL
SL
(         mol 1      mol 2)LN
EL
SL
(         10-20 <--> 15-25)LN
EL
SL
(         30-40 <--> 55-65)LN
EL
SL
(         50-60 <--> 35-45)LN
EL
SL
()LN
EL
SL
(     Just selecting all these atoms would take all)LN
EL
SL
(     fragments in ascending order, making the)LN
EL
SL
(     following superposition:)LN
EL
SL
()LN
EL
SL
(         mol 1      mol 2)LN
EL
SL
(         10-20 <--> 15-25)LN
EL
SL
(         30-40 <--> 35-45)LN
EL
SL
(         50-60 <--> 55-65)LN
EL
SL
()LN
EL
SL
(     For getting the desired result:)LN
EL
SL
()LN
EL
SL
(         DefPropAtom 'fragm1' '\(#1:10-20 #2:15-25\) & bb')LN
EL
SL
(         DefPropAtom 'fragm2' '\(#1:30-40 #2:55-65\) & bb')LN
EL
SL
(         DefPropAtom 'fragm3' '\(#1:50-60 #2:35-45\) & bb')LN
EL
SL
(         Fit to_first 'fragm1 fragm2 fragm3')LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Fit to_first 'selected')LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, Group, DialMol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     961217)LN
EL

