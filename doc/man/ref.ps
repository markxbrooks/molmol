SL
()LN
EL
SL
(NAME)LN
EL
SL
(     AddRibbon - add ribbons \(schematic drawing\))LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddRibbon)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Create a schematic drawing with ribbons. The ribbons)LN
EL
SL
(     will go through the currently selected atoms, this)LN
EL
SL
(     will normally be all CA atoms in a protein.)LN
EL
SL
()LN
EL
SL
(     If ribbons for helices and sheets are desired, certain)LN
EL
SL
(     properties of the residues must be set to give the)LN
EL
SL
(     necessary secondary structure information. The)LN
EL
SL
(     following properties are used:)LN
EL
SL
()LN
EL
SL
(         helix)LN
EL
SL
(         helix1, helix2,...)LN
EL
SL
(         sheet)LN
EL
SL
(         sheet1, sheet2,...)LN
EL
SL
(         strand1_1, strand1_2,...)LN
EL
SL
()LN
EL
SL
(     These properties are set when a PDB file containing)LN
EL
SL
(     secondary structure information \(HELIX and SHEET)LN
EL
SL
(     records\) is read, or they can be calculated with the)LN
EL
SL
(     CalcSecondary command. They can also be set/modified)LN
EL
SL
(     using the DefPropRes command, a more convenient way)LN
EL
SL
(     for modifying the result of CalcSecondary is often to)LN
EL
SL
(     use the WriteSecondary command.)LN
EL
SL
()LN
EL
SL
(     For sheets, the neighbour of the residues should be)LN
EL
SL
(     set with the SetNeigh command if the secondary)LN
EL
SL
(     structure was not read from a PDB file or calculated)LN
EL
SL
(     with CalcSecondary.)LN
EL
SL
()LN
EL
SL
(     The created primitives will have exactly one of the)LN
EL
SL
(     following properties set:)LN
EL
SL
()LN
EL
SL
(         helix)LN
EL
SL
(         sheet)LN
EL
SL
(         coil)LN
EL
SL
()LN
EL
SL
(     and for helix and sheet the numbered one from the )LN
EL
SL
(     residue \(helix1,...\) is also copied.)LN
EL
SL
()LN
EL
SL
(     In addition, all created primitives have the property)LN
EL
SL
(     "ribbon".)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddRibbon)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     ReadPdb, CalcSecondary, SelectAtom,)LN
EL
SL
(     WriteSecondary, DefPropRes, SetNeigh,)LN
EL
SL
(     LengthPrim, ColorPrim, TintPrim, ShadePrim,)LN
EL
SL
(     TypeRibbon, StyleRibbon, SizeRibbon, PaintRibbon)LN
EL
