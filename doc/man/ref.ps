SL
()LN
EL
SL
(NAME)LN
EL
SL
(     XMacStand - execute standard macro)LN
EL
SL
(     XMacUser  - execute user macro)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     XMacStand fileName)LN
EL
SL
(     XMacUser fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Execute a macro file. A macro file is a sequence of)LN
EL
SL
(     commands like they are entered on the command line.)LN
EL
SL
(     A history of all executed commands of each session is)LN
EL
SL
(     maintained in the file molmol/history in the users)LN
EL
SL
(     home directory. It can be used as macro.)LN
EL
SL
()LN
EL
SL
(     The two commands only differ in their search path.)LN
EL
SL
(     XMacStand by default searches in $MOLMOLHOME/macros,)LN
EL
SL
(     while XMacUser uses the current directory as default)LN
EL
SL
(     search path.)LN
EL
SL
()LN
EL
SL
(     Additonally to regular commands, macros can also)LN
EL
SL
(     contain command definitons. Once a macro with a)LN
EL
SL
(     command definiton is read in, this command can be used)LN
EL
SL
(     like a builtin MOLMOL command. A command definition)LN
EL
SL
(     has the syntax:)LN
EL
SL
()LN
EL
SL
(         define CommandName)LN
EL
SL
(         help one-line-help)LN
EL
SL
(         $arg1 = default1 prompt1)LN
EL
SL
(         ..)LN
EL
SL
(         $argN = defaultN promptN)LN
EL
SL
(         Command1)LN
EL
SL
(         ..)LN
EL
SL
(         CommandN)LN
EL
SL
(         end)LN
EL
SL
()LN
EL
SL
(     The help line is optional. The command can have any)LN
EL
SL
(     number of arguments \(including zero\). If no default)LN
EL
SL
(     value is given, the empty string is assumed the first)LN
EL
SL
(     time the command is executed, the previous value from)LN
EL
SL
(     there on. If the prompt is missing, the name of the)LN
EL
SL
(     argument is taken. If default values or prompts)LN
EL
SL
(     contain blanks or other special characters, they have)LN
EL
SL
(     to be written in single or double quotes.)LN
EL
SL
()LN
EL
SL
(     At least one command must be present in the body.)LN
EL
SL
(     Empty lines and comments \(staring with #\) are allowed,)LN
EL
SL
(     the lines can be indented for better readability.)LN
EL
SL
()LN
EL
SL
(     In the body, the arguments can be referenced by)LN
EL
SL
(     $arg or ${arg}. Any command can be used.)LN
EL
SL
()LN
EL
SL
(     Example:)LN
EL
SL
()LN
EL
SL
(         define ZoomRotate)LN
EL
SL
(           help zoom and rotate in one step)LN
EL
grestore

