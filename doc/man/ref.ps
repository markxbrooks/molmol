()LN
EL
SL
(NAME)LN
EL
SL
(     Fullscreen - switch fullscreen display on and off)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     Fullscreen \( off | on \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Switch fullscreen display on and off. Fullscreen)LN
EL
SL
(     mode is usefull for making screen photos and it is)LN
EL
SL
(     required for stereo display on some machines. Note)LN
EL
SL
(     that the menu and the command line are not visible)LN
EL
SL
(     in fullscreen mode. If the Fullscreen command is in)LN
EL
SL
(     the popup menu \(right mouse button\), this is the)LN
EL
SL
(     easiest way to switch back to normal mode. You can)LN
EL
SL
(     also type commands in fullscreen mode, but it is not)LN
EL
SL
(     very convenient because there is no feedback.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     Fullscreen on)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     Stereo)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     931129)LN
EL

