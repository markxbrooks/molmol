SL
(     AddBond - add bond between two atoms)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     AddBond)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Add a bond between the two selected atoms. Exactly)LN
EL
SL
(     two atoms must be selected before this command is)LN
EL
SL
(     executed, an error message will be issued otherwise.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     AddBond)LN
EL
