EL
SL
(NAME)LN
EL
SL
(     FirstMol - move molecules to front of molecule list)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     FirstMol)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Move all selected molecules to the front of the)LN
EL
SL
(     molecule list. This can be useful for commands that)LN
EL
SL
(     are sensitive to the order of molecules, most)LN
EL
SL
(     notably Fit.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     FirstMol)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, DialMol, Fit)LN
EL
SL
()LN
EL
