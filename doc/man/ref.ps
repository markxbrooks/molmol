52500 1034501 moveto
SL
(     that the "correct" gamma value depends on the output)LN
EL
SL
(     device used, so using gamma correction when producing)LN
EL
SL
(     the file is in principal not the right thing to do.)LN
EL
SL
(     We offer this possibilty for convenience sake, it is)LN
EL
SL
(     often difficult to do decent gamma correction on the)LN
EL
SL
(     output file \(e. g. for PostScript\) with other)LN
EL
SL
(     possibilities.)LN
EL
SL
()LN
EL
SL
(     The last parameter selects the quality for JPEG plots.)LN
EL
SL
(     Recommended values are between 50 \(strong compression)LN
EL
SL
(     with reasonable quality\) and 95 \(excellent quality\).)LN
EL
SL
()LN
EL
SL
(EXAMPLES)LN
EL
SL
(     PlotPar 21 29.7 18 0 1000 0 0 1 0 3 1.0 75)LN
EL
SL
(     PlotPar 21 29.7 0 18 2000 0 1 1 1 3 0.7 60)LN
EL
SL
(     PlotPar 29.7 42 0 26 1500 0 1 1 1 4 0.5 90)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotUnit, PlotPs, PlotFm*,)LN
EL
SL
(     PlotTiff, PlotJpeg, PlotPng, DrawPrec)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     960321)LN
EL

