(NAME)LN
EL
SL
(     PlotMpov - make a MegaPov plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotMpov fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Make a plot of the current screen contents in MegaPov)LN
EL
SL
(     format. MegaPov is an improved version of POV-Ray)LN
EL
SL
(     \(see PlotPov\). This command makes use of the extended)LN
EL
SL
(     possibilities of MegaPov in rendering surfaces with)LN
EL
SL
(     smooth color changes, e. g. surfaces colored by)LN
EL
SL
(     electrostatic potential.)LN
EL
SL
()LN
EL
SL
(     MegaPov is available from Nathan Kopp's web pages at)LN
EL
SL
(     http://nathan.kopp.com/patched.htm.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotMpov /home/joe/MyPlot.pov)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     PlotFm*, PlotPs, PlotTiff, PlotJpeg, PlotPng,)LN
EL
SL
