(     PlotUnit - set unit of plot parameters)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotUnit \( cm | mm | inch \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Set the unit used for paper and plot sizes in the)LN
EL
SL
(     PlotPar command. Changing the unit will also reset)LN
EL
SL
(     the paper size to the default associated with the)LN
EL
SL
(     unit, which is A4 for cm and mm and US Letter for)LN
EL
SL
(     inch.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     PlotUnit cm)LN
EL
SL
()LN
