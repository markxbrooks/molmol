SL
()LN
EL
SL
(NAME)LN
EL
SL
(     CalcCluster - reduce number of structures)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     CalcCluster expr expr expr)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Takes a bundle of superimposed structures and)LN
EL
SL
(     determines a smaller number of structures that)LN
EL
SL
(     represent the same bundle as well as possible. This is)LN
EL
SL
(     done by clustering similar structures into groups, and)LN
EL
SL
(     taking the "central" structure of each group.)LN
EL
SL
()LN
EL
SL
(     The command acts on all selected molecules and only)LN
EL
SL
(     considers the selected atoms of these molecules for)LN
EL
SL
(     the calculation.)LN
EL
SL
()LN
EL
SL
(     The first argument gives the desired number of)LN
EL
SL
(     structures. The second argument gives the minimal RMSD)LN
EL
SL
(     between two resulting groups, where the RMSD between)LN
EL
SL
(     two groups is defined as the maximal RMSD between a)LN
EL
SL
(     member of one group and a member of the other group.)LN
EL
SL
(     The third argument gives the maximal RMSD of two)LN
EL
SL
(     members of a group. Due to these restrictions, the)LN
EL
SL
(     number of calculated clusters can be different from)LN
EL
SL
(     the one given as first argument.)LN
EL
SL
()LN
EL
SL
(     The property "cluster" is set on all molecules that)LN
EL
SL
(     represent a group. From each group, the one with the)LN
EL
SL
(     smallest sum of RMSDs to all other members is chosen.)LN
EL
SL
(     A property \(cluster1, cluster2, etc.\) is also set for)LN
EL
SL
(     each member of every cluster.)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CalcCluster 5 0.02 1)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, SelectAtom, Group, Fit, MeanMol)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     980817)LN
EL

