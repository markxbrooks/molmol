SL
(NAME)LN
EL
SL
(     ReadOmap - read O electron density map)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     ReadOmap fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Read an electron density map from a plot file created)LN
EL
SL
(     by the program O. Only the commands "move", "line" and)LN
EL
SL
(     "rline" are interpreted, all other commands in the)LN
EL
SL
(     plot file are silently ignored.)LN
EL
SL
()LN
EL
SL
(     Exactly one molecule must be selected, the coordinates)LN
EL
SL
(     in the file are expected to be in the same coordinate)LN
EL
SL
(     space as this molecule.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     ReadOmap /home/joe/struct/my_map.plt)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectMol, StyleMap, LinePrim, ColorPrim)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     991023)LN
EL

