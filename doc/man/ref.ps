SL
()LN
EL
SL
(NAME)LN
EL
SL
(     CalcVdw - find Van der Waals violations)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     CalcVdw expr expr \( 0 | 1 \) \( 0 | 1 \) \( 0 | 1 \))LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Find pairs of selected atoms with Van der Waals)LN
EL
SL
(     violations larger than the cutoff given as first)LN
EL
SL
(     argument.)LN
EL
SL
()LN
EL
SL
(     The first option determines whether violations)LN
EL
SL
(     within structures or violations between atoms of)LN
EL
SL
(     different structures are desired.)LN
EL
SL
()LN
EL
SL
(     Depending on the other two options, the command will)LN
EL
SL
(     create a report with the violations, will add them)LN
EL
SL
(     to the display as lower distance limits, or both.)LN
EL
SL
(     Only violations that occur in a minimal number of)LN
EL
SL
(     structures given as third argument appear in the)LN
EL
SL
(     report.)LN
EL
SL
()LN
EL
SL
(     In the report produced by this command, a table of)LN
EL
SL
(     violations will be created for each set of molecules)LN
EL
SL
(     with the same structure. A '+' sign indicates that)LN
EL
SL
(     the violation is present in the molecule corresponding)LN
EL
SL
(     to the column, a '*' marks the largest of these)LN
EL
SL
(     violations. The '+' sign is replaced by a '5' for)LN
EL
SL
(     molecules 5, 15, 25, ... and by a '0' for molecules)LN
EL
SL
(     10, 20, 30, ...)LN
EL
SL
()LN
EL
SL
(     This command supports groups.)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
EL
SL
(     CalcVdw 0.3 1 0 1 0)LN
EL
SL
()LN
EL
SL
(SEE ALSO)LN
EL
SL
(     SelectAtom, Group, RemoveDist)LN
EL
SL
()LN
EL
SL
(DATE)LN
EL
SL
(     981101)LN
EL

