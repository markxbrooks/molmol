(     PlotPs - make a PostScript plot)LN
EL
SL
()LN
EL
SL
(SYNOPSIS)LN
EL
SL
(     PlotPs fileName)LN
EL
SL
()LN
EL
SL
(DESCRIPTION)LN
EL
SL
(     Make a PostScript plot of the current screen contents.)LN
EL
SL
(     Selection of the desired parameters with the PlotPar)LN
EL
SL
(     command is essential for obtaining good results.)LN
EL
SL
(     Hidden surface elimination of complex scenes can take)LN
EL
SL
(     some time \(up to a few minutes typically\).)LN
EL
SL
()LN
EL
SL
(EXAMPLE)LN
